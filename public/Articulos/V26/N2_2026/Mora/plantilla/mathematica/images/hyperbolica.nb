Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"PoincareGeodesic", ":", 
    RowBox[{
    "Dibuja", " ", "la", " ", "geod\[EAcute]sica", " ", "entre", " ", "P1", 
     " ", "y", " ", "P2", " ", "y", " ", "cinco", " ", "curvas", " ", 
     "paralelas"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"PoincareGeodesicParallels", "[", 
     RowBox[{"P1_", ",", "P2_", ",", "P3_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "x1", ",", "y1", ",", "x2", ",", "y2", ",", "x3", ",", "y3", ",", "z", 
        ",", "r", ",", "center", ",", "theta1", ",", "theta2", ",", "r3", ",",
         "curve", ",", "parallelCurves", ",", "points", ",", "radii", ",", 
        "colors"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x1", ",", "y1"}], "}"}], "=", "P1"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x2", ",", "y2"}], "}"}], "=", "P2"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x3", ",", "y3"}], "}"}], "=", "P3"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Graficar", " ", "puntos"}], "*)"}], 
       RowBox[{"points", "=", 
        RowBox[{"Graphics", "[", 
         RowBox[{"{", 
          RowBox[{"Black", ",", 
           RowBox[{"PointSize", "[", "Large", "]"}], ",", 
           RowBox[{"Point", "[", "P1", "]"}], ",", 
           RowBox[{"Point", "[", "P2", "]"}], ",", 
           RowBox[{"Point", "[", "P3", "]"}]}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"x1", "\[Equal]", "x2"}], ",", 
         RowBox[{"(*", 
          RowBox[{"Caso", " ", 
           RowBox[{"especial", ":", 
            RowBox[{"L\[IAcute]nea", " ", "vertical"}]}]}], "*)"}], 
         RowBox[{
          RowBox[{"curve", "=", 
           RowBox[{"ParametricPlot", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"x1", ",", "t"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"t", ",", 
               RowBox[{"Min", "[", 
                RowBox[{"y1", ",", "y2"}], "]"}], ",", 
               RowBox[{"Max", "[", 
                RowBox[{"y1", ",", "y2"}], "]"}]}], "}"}], ",", 
             RowBox[{"PlotStyle", "\[Rule]", "Thick"}], ",", 
             RowBox[{"PlotRange", "\[Rule]", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"0", ",", "5"}], "}"}]}], "}"}]}], ",", 
             RowBox[{"Axes", "\[Rule]", "True"}], ",", 
             RowBox[{"AxesOrigin", "\[Rule]", 
              RowBox[{"{", 
               RowBox[{"0", ",", "0"}], "}"}]}], ",", 
             RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
             RowBox[{"ImageSize", "\[Rule]", "400"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"parallelCurves", "=", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"ParametricPlot", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"x3", "+", 
                  RowBox[{"0.5", " ", 
                   RowBox[{"(", 
                    RowBox[{"k", "-", "3"}], ")"}]}]}], ",", "t"}], "}"}], 
               ",", 
               RowBox[{"{", 
                RowBox[{"t", ",", "0", ",", "y3"}], "}"}], ",", 
               RowBox[{"PlotStyle", "\[Rule]", 
                RowBox[{"{", 
                 RowBox[{"Thick", ",", "Dashed", ",", 
                  RowBox[{
                   RowBox[{"ColorData", "[", "\"\<Rainbow\>\"", "]"}], "[", 
                   RowBox[{"k", "/", "5"}], "]"}]}], "}"}]}], ",", 
               RowBox[{"PlotRange", "\[Rule]", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"0", ",", "5"}], "}"}]}], "}"}]}], ",", 
               RowBox[{"Axes", "\[Rule]", "None"}], ",", 
               RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
               RowBox[{"ImageSize", "\[Rule]", "400"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"Show", "[", 
            RowBox[{"curve", ",", "points", ",", "parallelCurves"}], "]"}], 
           "]"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Centro", " ", "y", " ", "radio", " ", "de", " ", "la", " ", 
         "circunferencia", " ", "original"}], "*)"}], 
       RowBox[{"z", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x1", "^", "2"}], "+", 
           RowBox[{"y1", "^", "2"}], "-", 
           RowBox[{"x2", "^", "2"}], "-", 
           RowBox[{"y2", "^", "2"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{"x1", "-", "x2"}], ")"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"r", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"x1", "-", "z"}], ")"}], "^", "2"}], "+", 
          RowBox[{"y1", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"center", "=", 
        RowBox[{"{", 
         RowBox[{"z", ",", "0"}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "\[CapitalAAcute]ngulos", " ", "para", " ", "la", " ", 
         "geod\[EAcute]sica", " ", "original"}], "*)"}], 
       RowBox[{"theta1", "=", 
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{"x1", "-", "z"}], ",", "y1"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"theta2", "=", 
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{"x2", "-", "z"}], ",", "y2"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Radio", " ", "de", " ", "la", " ", "circunferencia", " ", "que", " ",
          "pasa", " ", "por", " ", "P3", " ", "y", " ", "es", " ", "paralela",
          " ", "a", " ", "la", " ", "original"}], "*)"}], 
       RowBox[{"r3", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"x3", "-", "z"}], ")"}], "^", "2"}], "+", 
          RowBox[{"y3", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Crear", " ", "un", " ", "conjunto", " ", "de", " ", "radios", " ", 
         "para", " ", "las", " ", "curvas", " ", "paralelas"}], "*)"}], 
       RowBox[{"radii", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"r3", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"k", "-", "3"}], ")"}], "*", "0.5"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Colores", " ", "para", " ", "distinguir", " ", "cada", " ", "curva", 
         " ", "paralela"}], "*)"}], 
       RowBox[{"colors", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ColorData", "[", "\"\<Rainbow\>\"", "]"}], "[", 
           RowBox[{"k", "/", "5"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Geod\[EAcute]sica", " ", "original"}], "*)"}], 
       RowBox[{"curve", "=", 
        RowBox[{"ParametricPlot", "[", 
         RowBox[{
          RowBox[{"center", "+", 
           RowBox[{"r", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Cos", "[", "t", "]"}], ",", 
              RowBox[{"Sin", "[", "t", "]"}]}], "}"}]}]}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", 
            RowBox[{"Min", "[", 
             RowBox[{"theta1", ",", "theta2"}], "]"}], ",", 
            RowBox[{"Max", "[", 
             RowBox[{"theta1", ",", "theta2"}], "]"}]}], "}"}], ",", 
          RowBox[{"PlotStyle", "\[Rule]", "Thick"}], ",", 
          RowBox[{"PlotRange", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
