          RowBox[{"ImageSize", "\[Rule]", "400"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Curva", " ", "paralela", " ", "que", " ", "pasa", " ", "por", " ", 
         "P3"}], "*)"}], 
       RowBox[{"parallelCurve", "=", 
        RowBox[{"ParametricPlot", "[", 
         RowBox[{
          RowBox[{"center", "+", 
           RowBox[{"r3", " ", 
            RowBox[{"{", 
