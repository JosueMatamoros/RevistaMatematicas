Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PoincareGeodesic", "[", 
     RowBox[{"P1_", ",", "P2_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "x1", ",", "y1", ",", "x2", ",", "y2", ",", "z", ",", "r", ",", 
        "center", ",", "theta1", ",", "theta2"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x1", ",", "y1"}], "}"}], "=", "P1"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x2", ",", "y2"}], "}"}], "=", "P2"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Caso", " ", 
         RowBox[{"trivial", ":", 
          RowBox[{"l\[IAcute]nea", " ", "vertical"}]}]}], "*)"}], 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"x1", "\[Equal]", "x2"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"ParametricPlot", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"x1", ",", "t"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"t", ",", 
              RowBox[{"Min", "[", 
               RowBox[{"y1", ",", "y2"}], "]"}], ",", 
              RowBox[{"Max", "[", 
               RowBox[{"y1", ",", "y2"}], "]"}]}], "}"}], ",", 
            RowBox[{"PlotRange", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"0", ",", "5"}], "}"}]}], "}"}]}], ",", 
            RowBox[{"Axes", "\[Rule]", "True"}], ",", 
            RowBox[{"AxesOrigin", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}]}], ",", 
            RowBox[{"AspectRatio", "\[Rule]", "1"}]}], "]"}], "]"}]}], "]"}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Centro", " ", "y", " ", "radio", " ", "de", " ", "la", " ", 
         "circunferencia"}], "*)"}], 
       RowBox[{"z", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x1", "^", "2"}], "+", 
           RowBox[{"y1", "^", "2"}], "-", 
           RowBox[{"x2", "^", "2"}], "-", 
           RowBox[{"y2", "^", "2"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{"x1", "-", "x2"}], ")"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"r", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"x1", "-", "z"}], ")"}], "^", "2"}], "+", 
          RowBox[{"y1", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"center", "=", 
        RowBox[{"{", 
         RowBox[{"z", ",", "0"}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "\[CapitalAAcute]ngulos", " ", "para", " ", "el", " ", "arco", " ", 
         "de", " ", "circunferencia"}], "*)"}], 
       RowBox[{"theta1", "=", 
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{"x1", "-", "z"}], ",", "y1"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"theta2", "=", 
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{"x2", "-", "z"}], ",", "y2"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Dibujar", " ", "el", " ", "arco", " ", "completo"}], "*)"}], 
       
       RowBox[{"ParametricPlot", "[", 
        RowBox[{
         RowBox[{"center", "+", 
          RowBox[{"r", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Cos", "[", "t", "]"}], ",", 
             RowBox[{"Sin", "[", "t", "]"}]}], "}"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", 
           RowBox[{"Min", "[", 
            RowBox[{"theta1", ",", "theta2"}], "]"}], ",", 
           RowBox[{"Max", "[", 
            RowBox[{"theta1", ",", "theta2"}], "]"}]}], "}"}], ",", 
         RowBox[{"PlotRange", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "5"}], "}"}]}], "}"}]}], ",", 
         RowBox[{"Axes", "\[Rule]", "True"}], ",", 
         RowBox[{"AxesOrigin", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}]}], ",", 
         RowBox[{"AspectRatio", "\[Rule]", "1"}]}], "]"}]}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Ejemplo", ":", 
     RowBox[{
     "Graficar", " ", "la", " ", "geod\[EAcute]sica", " ", "de", " ", 
      "Poincar\[EAcute]", " ", "entre", " ", "dos", " ", "puntos", " ", "P1", 
      " ", "y", " ", "P2"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"P1", "=", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"P2", "=", 
     RowBox[{"{", 
      RowBox[{"4", ",", "1"}], "}"}]}], ";"}], "\n", 
   RowBox[{"PoincareGeodesic", "[", 
    RowBox[{"P1", ",", "P2"}], "]"}], "\n"}]}]], "Input",
 CellChangeTimes->{{3.9529438467573013`*^9, 3.952943847284465*^9}}],

