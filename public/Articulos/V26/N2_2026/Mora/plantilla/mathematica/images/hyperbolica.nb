Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"PoincareGeodesicParallels", ":", 
    RowBox[{
    "Dibuja", " ", "la", " ", "geod\[EAcute]sica", " ", "entre", " ", "P1", 
     " ", "y", " ", "P2", " ", "y", " ", "cinco", " ", "curvas", " ", 
     "paralelas", " ", "que", " ", "pasan", " ", "por", " ", "P3"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"PoincareGeodesicParallels", "[", 
     RowBox[{"P1_", ",", "P2_", ",", "P3_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "x1", ",", "y1", ",", "x2", ",", "y2", ",", "x3", ",", "y3", ",", "z", 
        ",", "r", ",", "center", ",", "theta1", ",", "theta2", ",", "r3", ",",
         "curve", ",", "parallelCurves", ",", "points", ",", "angles", ",", 
        "colors"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x1", ",", "y1"}], "}"}], "=", "P1"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x2", ",", "y2"}], "}"}], "=", "P2"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x3", ",", "y3"}], "}"}], "=", "P3"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Graficar", " ", "puntos"}], "*)"}], 
       RowBox[{"points", "=", 
        RowBox[{"Graphics", "[", 
         RowBox[{"{", 
          RowBox[{"Black", ",", 
           RowBox[{"PointSize", "[", "Large", "]"}], ",", 
           RowBox[{"Point", "[", "P1", "]"}], ",", 
           RowBox[{"Point", "[", "P2", "]"}], ",", 
           RowBox[{"Point", "[", "P3", "]"}]}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"x1", "\[Equal]", "x2"}], ",", 
         RowBox[{"(*", 
          RowBox[{"Caso", " ", 
           RowBox[{"especial", ":", 
            RowBox[{"L\[IAcute]nea", " ", "vertical"}]}]}], "*)"}], 
         RowBox[{
          RowBox[{"curve", "=", 
           RowBox[{"ParametricPlot", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"x1", ",", "t"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"t", ",", 
               RowBox[{"Min", "[", 
                RowBox[{"y1", ",", "y2"}], "]"}], ",", 
               RowBox[{"Max", "[", 
                RowBox[{"y1", ",", "y2"}], "]"}]}], "}"}], ",", 
             RowBox[{"PlotStyle", "\[Rule]", "Thick"}], ",", 
             RowBox[{"PlotRange", "\[Rule]", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"0", ",", "5"}], "}"}]}], "}"}]}], ",", 
             RowBox[{"Axes", "\[Rule]", "True"}], ",", 
             RowBox[{"AxesOrigin", "\[Rule]", 
              RowBox[{"{", 
               RowBox[{"0", ",", "0"}], "}"}]}], ",", 
             RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
             RowBox[{"ImageSize", "\[Rule]", "400"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"Show", "[", 
            RowBox[{"curve", ",", "points"}], "]"}], "]"}], ";"}]}], "]"}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Centro", " ", "y", " ", "radio", " ", "de", " ", "la", " ", 
         "circunferencia", " ", "original"}], "*)"}], 
       RowBox[{"z", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x1", "^", "2"}], "+", 
           RowBox[{"y1", "^", "2"}], "-", 
           RowBox[{"x2", "^", "2"}], "-", 
           RowBox[{"y2", "^", "2"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{"x1", "-", "x2"}], ")"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"r", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"x1", "-", "z"}], ")"}], "^", "2"}], "+", 
          RowBox[{"y1", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"center", "=", 
        RowBox[{"{", 
         RowBox[{"z", ",", "0"}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "\[CapitalAAcute]ngulos", " ", "para", " ", "la", " ", 
         "geod\[EAcute]sica", " ", "original"}], "*)"}], 
       RowBox[{"theta1", "=", 
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{"x1", "-", "z"}], ",", "y1"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"theta2", "=", 
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{"x2", "-", "z"}], ",", "y2"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Radio", " ", "de", " ", "la", " ", "circunferencia", " ", "que", " ",
          "pasa", " ", "por", " ", "P3", " ", "y", " ", "es", " ", "paralela",
          " ", "a", " ", "la", " ", "original"}], "*)"}], 
       RowBox[{"r3", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"x3", "-", "z"}], ")"}], "^", "2"}], "+", 
          RowBox[{"y3", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Geod\[EAcute]sica", " ", "principal", " ", "entre", " ", "P1", " ", 
         "y", " ", "P2"}], "*)"}], 
       RowBox[{"curve", "=", 
        RowBox[{"ParametricPlot", "[", 
         RowBox[{
          RowBox[{"center", "+", 
           RowBox[{"r", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Cos", "[", "t", "]"}], ",", 
              RowBox[{"Sin", "[", "t", "]"}]}], "}"}]}]}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", 
            RowBox[{"Min", "[", 
             RowBox[{"theta1", ",", "theta2"}], "]"}], ",", 
            RowBox[{"Max", "[", 
             RowBox[{"theta1", ",", "theta2"}], "]"}]}], "}"}], ",", 
          RowBox[{"PlotStyle", "\[Rule]", "Thick"}], ",", 
          RowBox[{"PlotRange", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", "5"}], "}"}]}], "}"}]}], ",", 
          RowBox[{"Axes", "\[Rule]", "True"}], ",", 
          RowBox[{"AxesOrigin", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{"0", ",", "0"}], "}"}]}], ",", 
          RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
          RowBox[{"ImageSize", "\[Rule]", "400"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Crear", " ", "\[AAcute]ngulos", " ", "desplazados", " ", "para", " ",
          "curvas", " ", "paralelas", " ", "que", " ", "pasan", " ", "por", 
         " ", "P3"}], "*)"}], 
       RowBox[{"angles", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ArcTan", "[", 
            RowBox[{
             RowBox[{"x3", "-", "z"}], ",", "y3"}], "]"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"k", "-", "3"}], ")"}], "*", "0.3"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"colors", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ColorData", "[", "\"\<Rainbow\>\"", "]"}], "[", 
           RowBox[{"k", "/", "5"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Curvas", " ", "paralelas", " ", "que", " ", "pasan", " ", "por", " ",
          "P3"}], "*)"}], 
       RowBox[{"parallelCurves", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"ParametricPlot", "[", 
           RowBox[{
            RowBox[{"center", "+", 
             RowBox[{"r3", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Cos", "[", "t", "]"}], ",", 
                RowBox[{"Sin", "[", "t", "]"}]}], "}"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"t", ",", 
              RowBox[{"Min", "[", 
               RowBox[{
                RowBox[{"angles", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], ",", 
                RowBox[{"Pi", "-", 
                 RowBox[{"angles", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}]}], "]"}], ",", 
              RowBox[{"Max", "[", 
               RowBox[{
                RowBox[{"angles", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], ",", 
                RowBox[{"Pi", "-", 
                 RowBox[{"angles", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}]}], "]"}]}], "}"}], ",", 
            RowBox[{"PlotStyle", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"Thick", ",", "Dashed", ",", 
               RowBox[{"colors", "[", 
                RowBox[{"[", "k", "]"}], "]"}]}], "}"}]}], ",", 
            RowBox[{"PlotRange", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"0", ",", "5"}], "}"}]}], "}"}]}], ",", 
            RowBox[{"Axes", "\[Rule]", "None"}], ",", 
            RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
            RowBox[{"ImageSize", "\[Rule]", "400"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Show", "[", 
        RowBox[{"curve", ",", "points", ",", "parallelCurves"}], "]"}]}]}], 
     "]"}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Ejemplo", ":", 
     RowBox[{
     "Graficar", " ", "la", " ", "geod\[EAcute]sica", " ", "entre", " ", "P1",
       " ", "y", " ", "P2", " ", "y", " ", "cinco", " ", "curvas", " ", 
      "paralelas", " ", "que", " ", "pasan", " ", "por", " ", "P3"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"P1", "=", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"P2", "=", 
     RowBox[{"{", 
      RowBox[{"4", ",", "1"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"P3", "=", 
     RowBox[{"{", 
      RowBox[{"3", ",", "3"}], "}"}]}], ";"}], "\n", 
   RowBox[{"PoincareGeodesicParallels", "[", 
    RowBox[{"P1", ",", "P2", ",", "P3"}], "]"}], "\n"}]}]], "Input",
 CellChangeTimes->{{3.952971033993181*^9, 3.952971035062189*^9}}],

