Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Needs", "[", "\"\<MaTeX`\>\"", "]"}], "\n", 
   RowBox[{
    RowBox[{"SetOptions", "[", 
     RowBox[{"MaTeX", ",", 
      RowBox[{"\"\<Preamble\>\"", "\[Rule]", 
       RowBox[{
       "{", "\"\<\\\\usepackage{xcolor,pslatex,pstricks}\>\"", "}"}]}]}], 
     "]"}], ";"}], "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.745861295621334*^9, 3.7458613299581203`*^9}, 
   3.745877241701627*^9, {3.74587948390346*^9, 3.745879521622211*^9}},
 ExpressionUUID -> "b3b18e7b-1262-4455-9b25-3b5b9bf90a31"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"MaTeX", "[", 
     RowBox[{"\"\<n =\\\\;\>\"", ",", 
      RowBox[{"Magnification", "\[Rule]", "1.3"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"MaTeX", "[", 
     RowBox[{"\"\<f(x)=-x^3+x^2+x+3\>\"", ",", 
      RowBox[{"Magnification", "\[Rule]", "1.3"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"MaTeX", "[", 
     RowBox[{"\"\<n\>\"", ",", 
      RowBox[{"Magnification", "\[Rule]", "1.3"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"MaTeX", "[", 
     RowBox[{"\"\<\\\\to \\\\infty\>\"", ",", 
      RowBox[{"Magnification", "\[Rule]", "1.3"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"MaTeX", "[", 
     RowBox[{"\"\<\\\\sum_{k=1}^nf(x_k)\\\\Delta x\>\"", ",", 
      RowBox[{"Magnification", "\[Rule]", "1.2"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"MaTeX", "[", 
     RowBox[{
     "\"\<\\\\int_{0}^{2}f(x)\\\\,dx=\\\\lim_{n\\\\to\\\\infty}\\\\sum_{k=1}^\
nf(\\\\xi_k)\\\\Delta x,\\;\\;\\;\\; \\\\xi_k=x_k=\\\\mbox{{\\\\small \
$0+(k-1)\\\\dfrac{2}{n}$ }}\>\"", ",", 
      RowBox[{"Magnification", "\[Rule]", "1.4"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Graphics", "[", 
     RowBox[{
      RowBox[{"Locator", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], "]"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"ImageSize", "\[Rule]", "17"}]}], "]"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.745861333845442*^9, 3.7458613432380953`*^9}, {
