   RowBox[{"{", 
    RowBox[{
     RowBox[{"MaTeX", "[", 
      RowBox[{
      "\"\<\\\\int_{0}^{2}f(x)\\\\,dx=\\\\lim_{n\\\\to\\\\infty}\\\\sum_{k=1}^\
nf(\\\\xi_k)\\\\Delta x,\\;\\;\\;\\; \\\\xi_k=x_{k-1}=\\\\mbox{{\\\\small \
$0+(k-1)\\\\dfrac{2}{n}$ }}\>\"", ",", 
       RowBox[{"Magnification", "\[Rule]", "1.4"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"MaTeX", "[", 
