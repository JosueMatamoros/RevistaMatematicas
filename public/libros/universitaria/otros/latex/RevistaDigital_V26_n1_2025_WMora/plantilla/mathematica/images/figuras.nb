Cell[CellGroupData[{

Cell["Geodesicas", "Section",
 CellChangeTimes->{{3.952939847141922*^9, 3.95293985836731*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"GeodesicaPoincare", "[", 
    RowBox[{"P1_", ",", "P2_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "x1", ",", "y1", ",", "x2", ",", "y2", ",", "center", ",", "radius", 
       ",", "theta1", ",", "theta2"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{"Coordenadas", " ", "de", " ", "los", " ", "puntos"}], "*)"}], 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x1", ",", "y1"}], "}"}], "=", "P1"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x2", ",", "y2"}], "}"}], "=", "P2"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"x1", "\[Equal]", "x2"}], ",", 
        RowBox[{"(*", 
         RowBox[{"Caso", " ", 
          RowBox[{"especial", ":", 
           RowBox[{"L\[IAcute]nea", " ", "vertical"}]}]}], "*)"}], 
        RowBox[{"Plot", "[", 
         RowBox[{
          RowBox[{"{", "x1", "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"y", ",", 
            RowBox[{"Min", "[", 
             RowBox[{"y1", ",", "y2"}], "]"}], ",", 
            RowBox[{"Max", "[", 
             RowBox[{"y1", ",", "y2"}], "]"}]}], "}"}], ",", 
          RowBox[{"PlotStyle", "\[Rule]", "Thick"}]}], "]"}], ",", 
        RowBox[{"(*", 
         RowBox[{"Caso", " ", 
          RowBox[{"general", ":", 
           RowBox[{
           "Circunferencia", " ", "ortogonal", " ", "al", " ", "eje", " ", 
            "x"}]}]}], "*)"}], 
        RowBox[{
         RowBox[{"center", "=", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"x1", "^", "2"}], "-", 
             RowBox[{"x2", "^", "2"}], "+", 
             RowBox[{"y1", "^", "2"}], "-", 
             RowBox[{"y2", "^", "2"}]}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"(", 
              RowBox[{"x1", "-", "x2"}], ")"}]}], ")"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"radius", "=", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"x1", "-", "center"}], ")"}], "^", "2"}], "+", 
            RowBox[{"y1", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"ParametricPlot", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"center", "+", 
              RowBox[{"radius", " ", 
               RowBox[{"Cos", "[", "t", "]"}]}]}], ",", 
             RowBox[{"radius", " ", 
              RowBox[{"Sin", "[", "t", "]"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", 
             RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
           RowBox[{"PlotRange", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "1"}], ",", "4"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "4"}], "}"}]}], "}"}]}], ",", 
           RowBox[{"Axes", "\[Rule]", "True"}], ",", 
           RowBox[{"AxesOrigin", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0"}], "}"}]}], ",", 
           RowBox[{"PlotStyle", "\[Rule]", "Thick"}]}], "]"}]}]}], "]"}]}]}], 
    "]"}]}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Ejemplo", " ", "de", " ", 
    RowBox[{"uso", ":"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"GeodesicaPoincare", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "0.2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"3", ",", "0.2"}], "}"}]}], "]"}], "\n"}], "Input",
 CellChangeTimes->{{3.95294087225432*^9, 3.952940872260932*^9}}],

Cell[BoxData[
 GraphicsBox[{{}, {}, 
