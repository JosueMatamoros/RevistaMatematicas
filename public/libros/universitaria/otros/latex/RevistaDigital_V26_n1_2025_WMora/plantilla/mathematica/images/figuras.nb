       "Geod\[EAcute]sica", " ", "principal", " ", "en", " ", "negro", " ", 
        "grueso"}], "*)"}], 
      RowBox[{
       RowBox[{"mainGeodesic", "=", 
        RowBox[{"Graphics", "[", 
         RowBox[{"{", 
          RowBox[{"Thick", ",", "Black", ",", 
           RowBox[{"poincareLine", "[", 
            RowBox[{"{", 
             RowBox[{"P1", ",", "P2"}], "}"}], "]"}]}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Generar", " ", "geod\[EAcute]sicas", " ", "paralelas", " ", "que", 
         " ", "pasan", " ", "por", " ", "P3"}], "*)"}], 
       RowBox[{"delta", "=", "0.1"}], ";", 
       RowBox[{"(*", 
        RowBox[{
        "Separaci\[OAcute]n", " ", "entre", " ", "geod\[EAcute]sicas", " ", 
         "paralelas"}], "*)"}], 
       RowBox[{"parallels", "=", 
        RowBox[{"Table", "[", 
