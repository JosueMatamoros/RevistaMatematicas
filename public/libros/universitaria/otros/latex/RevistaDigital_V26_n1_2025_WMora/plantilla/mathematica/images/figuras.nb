          RowBox[{"p1", "+", "p2"}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"p1", ".", "p2"}]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"r", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Norm", "[", "c", "]"}], "^", "2"}], "-", "1"}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"c", ",", 
         RowBox[{"Abs", "[", "r", "]"}]}], "}"}]}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Dibujar", " ", "circunferencia", " ", "de", " ", "geod\[EAcute]sica"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"drawGeodesic", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"p1_", ",", "p2_"}], "}"}], ",", "color_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"c", ",", "r"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"c", ",", "r"}], "}"}], "=", 
        RowBox[{"calculateCircle", "[", 
         RowBox[{"{", 
          RowBox[{"p1", ",", "p2"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"c", "===", 
          RowBox[{"{", "}"}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Graphics", "[", 
        RowBox[{"{", 
         RowBox[{"color", ",", "Thick", ",", 
          RowBox[{"Circle", "[", 
           RowBox[{"c", ",", "r"}], "]"}]}], "}"}], "]"}]}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Generar", " ", "geod\[EAcute]sicas", " ", "paralelas", " ", "basadas", 
     " ", "en", " ", "P3"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"generateParallel", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"p3_", ",", "p2_"}], "}"}], ",", "angle_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"c", ",", "r", ",", "rotatedP3"}], "}"}], ",", 
      RowBox[{
       RowBox[{"rotatedP3", "=", 
        RowBox[{
         RowBox[{"RotationTransform", "[", "angle", "]"}], "[", "p3", "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"drawGeodesic", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"rotatedP3", ",", "p2"}], "}"}], ",", "Red"}], "]"}]}]}], 
     "]"}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Funci\[OAcute]n", " ", "principal", " ", "para", " ", "dibujar", " ", 
     "la", " ", "geod\[EAcute]sica", " ", "principal", " ", "y", " ", "sus", 
     " ", "paralelas"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"GeodesicasPoincareDisco", "[", 
     RowBox[{"P1_", ",", "P2_", ",", "P3_", ",", "n_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "mainGeodesic", ",", "parallels", ",", "delta", ",", "angle", ",", 
        "points"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Geod\[EAcute]sica", " ", "principal", " ", "en", " ", "negro", " ", 
        "que", " ", "pasa", " ", "por", " ", "P1", " ", "y", " ", "P2"}], 
       "*)"}], 
      RowBox[{
       RowBox[{"mainGeodesic", "=", 
        RowBox[{"drawGeodesic", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"P1", ",", "P2"}], "}"}], ",", "Black"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Dibujar", " ", "los", " ", "puntos", " ", "P1"}], ",", 
         RowBox[{"P2", " ", "y", " ", "P3"}]}], "*)"}], 
       RowBox[{"points", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"drawPoint", "[", "P1", "]"}], ",", 
          RowBox[{"drawPoint", "[", "P2", "]"}], ",", 
          RowBox[{"drawPoint", "[", "P3", "]"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Generar", " ", "geod\[EAcute]sicas", " ", "paralelas", " ", "que", 
         " ", "pasan", " ", "por", " ", "P3"}], "*)"}], 
       RowBox[{"delta", "=", 
        RowBox[{"Pi", "/", "12"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{
        "Separaci\[OAcute]n", " ", "angular", " ", "entre", " ", 
         "geod\[EAcute]sicas", " ", "paralelas"}], "*)"}], 
       RowBox[{"parallels", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
