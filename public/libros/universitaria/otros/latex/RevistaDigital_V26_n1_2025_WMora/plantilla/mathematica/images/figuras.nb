                RowBox[{"{", 
                 RowBox[{"P3", ",", "P2"}], "}"}], ",", 
                RowBox[{"k", " ", "delta"}]}], "]"}]}], ";", 
             "\[IndentingNewLine]", "parallel"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{
             RowBox[{"-", "n"}], "/", "2"}], ",", 
            RowBox[{"n", "/", "2"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Mostrar", " ", "todo", " ", "en", " ", "el", " ", "disco", " ", "de",
          " ", "Poincar\[EAcute]"}], "*)"}], 
       RowBox[{"Show", "[", 
        RowBox[{
         RowBox[{"{", 
