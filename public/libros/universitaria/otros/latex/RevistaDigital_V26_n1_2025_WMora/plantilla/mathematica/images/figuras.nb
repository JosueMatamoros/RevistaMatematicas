     " ", "Poincar\[EAcute]"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"poincareLine", "[", 
     RowBox[{"{", 
      RowBox[{"p1_", ",", "p2_"}], "}"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"s", "=", 
         RowBox[{
          RowBox[{"p1", ".", "p2"}], "-", "1"}]}], ",", 
        RowBox[{"tm", "=", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"p2", ",", "p1"}], "}"}], "]"}]}]}], "}"}], ",", 
      RowBox[{"BSplineCurve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"p1", ",", 
          RowBox[{
           RowBox[{"tm", ".", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"p1", ".", "p1"}], ",", 
                RowBox[{"p2", ".", "p2"}]}], "}"}], "-", "1"}], ")"}]}], "/", 
           
           RowBox[{"(", 
            RowBox[{"2", " ", "s"}], ")"}]}], ",", "p2"}], "}"}], ",", 
        RowBox[{"SplineDegree", "\[Rule]", "2"}], ",", 
        RowBox[{"SplineKnots", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "0", ",", "1", ",", "1", ",", "1"}], 
          "}"}]}], ",", 
        RowBox[{"SplineWeights", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"1", ",", 
           RowBox[{"1", "/", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Det", "[", "tm", "]"}], "/", "s"}], ")"}], "^", 
               "2"}]}], "]"}]}], ",", "1"}], "}"}]}]}], "]"}]}], "]"}]}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Funci\[OAcute]n", " ", "principal", " ", "para", " ", "dibujar", " ", 
     "la", " ", "geod\[EAcute]sica", " ", "principal", " ", "y", " ", "sus", 
     " ", "paralelas"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"GeodesicasPoincareDisco", "[", 
     RowBox[{"P1_", ",", "P2_", ",", "P3_", ",", "n_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"mainGeodesic", ",", "parallels", ",", "delta"}], "}"}], ",", 
      RowBox[{"(*", 
