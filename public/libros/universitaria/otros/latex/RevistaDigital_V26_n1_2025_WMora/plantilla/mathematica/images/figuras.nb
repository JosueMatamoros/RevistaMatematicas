           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"u", ".", "u"}]}], ")"}], " ", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"v", ".", "v"}]}], ")"}]}], ")"}]}]}]}], "]"}], "]"}]}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Geod\[EAcute]sica", " ", "entre", " ", "dos", " ", "puntos", " ", 
     "usando", " ", "NURBS", " ", "en", " ", "el", " ", "Disco", " ", "de", 
     " ", "Poincar\[EAcute]"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"poincareLine", "[", 
     RowBox[{"{", 
      RowBox[{"p1_", ",", "p2_"}], "}"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"s", "=", 
         RowBox[{
          RowBox[{"p1", ".", "p2"}], "-", "1"}]}], ",", 
        RowBox[{"tm", "=", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"p2", ",", "p1"}], "}"}], "]"}]}], ",", "extendedP1", ",", 
        "extendedP2"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Extender", " ", "puntos", " ", "hasta", " ", "el", " ", "borde", " ", 
        "del", " ", "disco"}], "*)"}], 
      RowBox[{
       RowBox[{"extendedP1", "=", 
        RowBox[{"p1", "/", 
         RowBox[{"Norm", "[", "p1", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"extendedP2", "=", 
        RowBox[{"p2", "/", 
         RowBox[{"Norm", "[", "p2", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"BSplineCurve", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"extendedP1", ",", 
           RowBox[{
