               RowBox[{"{", 
                RowBox[{
                 RowBox[{"extendedP1", ".", "extendedP1"}], ",", 
                 RowBox[{"extendedP2", ".", "extendedP2"}]}], "}"}], "-", 
               "1"}], ")"}]}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "s"}], ")"}]}], ",", "extendedP2"}], "}"}], 
         ",", 
         RowBox[{"SplineDegree", "\[Rule]", "2"}], ",", 
         RowBox[{"SplineKnots", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "0", ",", "1", ",", "1", ",", "1"}], 
           "}"}]}], ",", 
