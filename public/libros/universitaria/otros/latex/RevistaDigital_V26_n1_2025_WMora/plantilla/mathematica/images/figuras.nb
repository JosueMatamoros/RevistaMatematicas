Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"poincareMetric", "[", 
     RowBox[{
      RowBox[{"u_", "?", "VectorQ"}], ",", 
      RowBox[{"v_", "?", "VectorQ"}]}], "]"}], ":=", 
    RowBox[{"Abs", "[", 
     RowBox[{"ArcCosh", "[", 
      RowBox[{"1", "+", 
       RowBox[{"2", " ", 
        RowBox[{
         RowBox[{"SquaredEuclideanDistance", "[", 
          RowBox[{"u", ",", "v"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"u", ".", "u"}]}], ")"}], " ", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"v", ".", "v"}]}], ")"}]}], ")"}]}]}]}], "]"}], "]"}]}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "NURBS", " ", "representation", " ", "of", " ", "a", " ", "line", " ", 
     "on", " ", "the", " ", "Poincar\[EAcute]", " ", "disk"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"poincareLine", "[", 
     RowBox[{"{", 
      RowBox[{"p1_", ",", "p2_"}], "}"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"s", "=", 
         RowBox[{
          RowBox[{"p1", ".", "p2"}], "-", "1"}]}], ",", 
        RowBox[{"tm", "=", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"p2", ",", "p1"}], "}"}], "]"}]}]}], "}"}], ",", 
      RowBox[{"BSplineCurve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"p1", ",", 
          RowBox[{
           RowBox[{"tm", ".", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"p1", ".", "p1"}], ",", 
                RowBox[{"p2", ".", "p2"}]}], "}"}], "-", "1"}], ")"}]}], "/", 
           
           RowBox[{"(", 
            RowBox[{"2", " ", "s"}], ")"}]}], ",", "p2"}], "}"}], ",", 
        RowBox[{"SplineDegree", "\[Rule]", "2"}], ",", 
        RowBox[{"SplineKnots", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "0", ",", "1", ",", "1", ",", "1"}], 
          "}"}]}], ",", 
        RowBox[{"SplineWeights", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"1", ",", 
           RowBox[{"1", "/", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Det", "[", "tm", "]"}], "/", "s"}], ")"}], "^", 
               "2"}]}], "]"}]}], ",", "1"}], "}"}]}]}], "]"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"n", "=", "20"}], 
       RowBox[{"(*", 
        RowBox[{"number", " ", "of", " ", "points"}], "*)"}], ",", 
       RowBox[{"r", "=", "3"}], ",", 
       RowBox[{"(*", 
        RowBox[{"hyperbolic", " ", "radius", " ", "of", " ", "disk"}], "*)"}], 
       RowBox[{"h", "=", "0.35"}]}], " ", 
      RowBox[{"(*", 
       RowBox[{
       "fraction", " ", "of", " ", "radius", " ", "to", " ", "consider", " ", 
        "drawing", " ", "an", " ", "edge"}], "*)"}], "}"}], ",", 
     RowBox[{
      RowBox[{"BlockRandom", "[", 
       RowBox[{
        RowBox[{"SeedRandom", "[", 
         RowBox[{"42", ",", 
          RowBox[{"Method", "\[Rule]", "\"\<MersenneTwister\>\""}]}], "]"}], 
        ";", 
        RowBox[{"(*", 
         RowBox[{"for", " ", "reproducibility"}], "*)"}], 
        RowBox[{"pts", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"With", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"t", "=", 
                RowBox[{"RandomReal", "[", "]"}]}], "}"}], ",", 
              RowBox[{"(*", 
               RowBox[{"hint", ":", 
                RowBox[{"derive", " ", "the", " ", "inverse", " ", "CDF"}]}], 
               "*)"}], 
              RowBox[{"Sqrt", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"t", " ", 
                  RowBox[{
                   RowBox[{"Sinh", "[", 
                    RowBox[{"r", "/", "2"}], "]"}], "^", "2"}]}], ")"}], "/", 
                
                RowBox[{"(", 
                 RowBox[{"1", "+", 
                  RowBox[{"t", " ", 
                   RowBox[{
                    RowBox[{"Sinh", "[", 
                    RowBox[{"r", "/", "2"}], "]"}], "^", "2"}]}]}], ")"}]}], 
               "]"}]}], "]"}], " ", 
            RowBox[{"Normalize", "[", 
             RowBox[{"RandomVariate", "[", 
              RowBox[{
               RowBox[{"NormalDistribution", "[", "]"}], ",", "2"}], "]"}], 
             "]"}]}], ",", 
           RowBox[{"{", "n", "}"}]}], "]"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"NearestNeighborGraph", "[", 
       RowBox[{"pts", ",", 
        RowBox[{"{", 
         RowBox[{"All", ",", 
          RowBox[{"h", " ", "r"}]}], "}"}], ",", 
        RowBox[{"DistanceFunction", "\[Rule]", "poincareMetric"}], ",", 
        RowBox[{"EdgeShapeFunction", "\[Rule]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"poincareLine", "[", "#1", "]"}], "&"}], ")"}]}], ",", 
        RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
        RowBox[{"Prolog", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Directive", "[", 
            RowBox[{
             RowBox[{"Opacity", "[", 
              RowBox[{"1", "/", "2"}], "]"}], ",", 
             RowBox[{"AbsoluteThickness", "[", "1", "]"}]}], "]"}], ",", 
           RowBox[{"Circle", "[", "]"}]}], "}"}]}]}], "]"}]}]}], "]"}], 
   "\n"}]}]], "Input",
 CellChangeTimes->{{3.952942293673429*^9, 3.9529423432969093`*^9}, {
  3.952942492924164*^9, 3.9529425099490747`*^9}}],

