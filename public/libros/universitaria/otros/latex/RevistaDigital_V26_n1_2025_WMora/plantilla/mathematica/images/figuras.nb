Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"GeodesicasPoincareDisco", "[", 
     RowBox[{"P1_", ",", "P2_", ",", "P3_", ",", "n_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "z1", ",", "z2", ",", "z3", ",", "mainGeodesic", ",", "parallels", ",",
         "delta", ",", "CircleFromPoints"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Funci\[OAcute]n", " ", "para", " ", "hallar", " ", "centro", " ", "y",
         " ", "radio", " ", "de", " ", "la", " ", "circunferencia", " ", 
        "que", " ", "pasa", " ", "por", " ", "dos", " ", "puntos", " ", "en", 
        " ", "el", " ", "disco"}], "*)"}], 
      RowBox[{
       RowBox[{
        RowBox[{"CircleFromPoints", "[", 
         RowBox[{"p1_", ",", "p2_"}], "]"}], ":=", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"m", ",", "c", ",", "r"}], "}"}], ",", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Norm", "[", "p1", "]"}], "\[Equal]", "1"}], "||", 
              RowBox[{
               RowBox[{"Norm", "[", "p2", "]"}], "\[Equal]", "1"}]}], ",", 
             RowBox[{"Return", "[", 
              RowBox[{"{", "}"}], "]"}]}], "]"}], ";", 
           RowBox[{"(*", 
            RowBox[{
            "Los", " ", "puntos", " ", "deben", " ", "estar", " ", "dentro", 
             " ", "del", " ", "disco"}], "*)"}], 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"p1", "===", 
              RowBox[{"-", "p2"}]}], ",", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{"Si", " ", "son", " ", "opuestos"}], ",", 
               RowBox[{
               "la", " ", "geod\[EAcute]sica", " ", "es", " ", "un", " ", 
                "di\[AAcute]metro"}]}], "*)"}], 
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
             RowBox[{"(*", 
              RowBox[{"Centro", " ", "del", " ", "disco"}], "*)"}], 
             RowBox[{"(*", 
              RowBox[{"Caso", " ", 
               RowBox[{"general", ":", 
                RowBox[{
                "c\[AAcute]lculo", " ", "del", " ", "c\[IAcute]rculo", " ", 
                 "ortogonal", " ", "al", " ", "borde"}]}]}], "*)"}], 
             RowBox[{
              RowBox[{"c", "=", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"p1", "+", "p2"}], ")"}], "/", 
                RowBox[{"(", 
                 RowBox[{"1", "+", 
                  RowBox[{"p1", ".", "p2"}]}], ")"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"r", "=", 
               RowBox[{"Sqrt", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Norm", "[", "c", "]"}], "^", "2"}], "-", "1"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"{", 
               RowBox[{"c", ",", 
                RowBox[{"Abs", "[", "r", "]"}]}], "}"}]}]}], "]"}]}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Geod\[EAcute]sica", " ", "principal", " ", "entre", " ", "P1", " ", 
         "y", " ", "P2"}], "*)"}], 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"z1", ",", "z2"}], "}"}], "=", 
        RowBox[{"{", 
         RowBox[{"P1", ",", "P2"}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"mainCenter", ",", "mainRadius"}], "}"}], "=", 
        RowBox[{"CircleFromPoints", "[", 
         RowBox[{"z1", ",", "z2"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"mainGeodesic", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"mainCenter", "===", 
           RowBox[{"{", 
            RowBox[{"0", ",", "0"}], "}"}]}], ",", 
          RowBox[{"(*", 
           RowBox[{"Si", " ", "es", " ", "un", " ", "di\[AAcute]metro"}], 
           "*)"}], 
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{"P1", ",", "P2"}], "}"}], "]"}], ",", 
          RowBox[{"(*", 
           RowBox[{
           "Si", " ", "es", " ", "un", " ", "arco", " ", "de", " ", 
            "circunferencia"}], "*)"}], 
          RowBox[{"ParametricPlot", "[", 
           RowBox[{
            RowBox[{"mainCenter", "+", 
             RowBox[{"mainRadius", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Cos", "[", "t", "]"}], ",", 
                RowBox[{"Sin", "[", "t", "]"}]}], "}"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"t", ",", "0", ",", 
              RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
            RowBox[{"PlotStyle", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"Thick", ",", "Black"}], "}"}]}]}], "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Generar", " ", "geod\[EAcute]sicas", " ", "paralelas", " ", "que", 
         " ", "pasan", " ", "por", " ", "P3"}], "*)"}], 
       RowBox[{"delta", "=", "0.1"}], ";", 
       RowBox[{"(*", 
        RowBox[{
        "Separaci\[OAcute]n", " ", "entre", " ", "geod\[EAcute]sicas", " ", 
         "paralelas"}], "*)"}], 
       RowBox[{"z3", "=", "P3"}], ";", "\[IndentingNewLine]", 
       RowBox[{"parallels", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"newP1", ",", "newCenter", ",", "newRadius"}], "}"}], 
            ",", 
            RowBox[{
             RowBox[{"newP1", "=", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"P3", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "+", 
                 RowBox[{"k", " ", "delta"}]}], ",", 
                RowBox[{"P3", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], "}"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"newCenter", ",", "newRadius"}], "}"}], "=", 
              RowBox[{"CircleFromPoints", "[", 
               RowBox[{"newP1", ",", "P2"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"newCenter", "===", 
                RowBox[{"{", "}"}]}], ",", "Nothing", ",", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"newCenter", "===", 
                  RowBox[{"{", 
                   RowBox[{"0", ",", "0"}], "}"}]}], ",", 
                 RowBox[{"Line", "[", 
                  RowBox[{"{", 
                   RowBox[{"newP1", ",", "P2"}], "}"}], "]"}], ",", 
                 RowBox[{"ParametricPlot", "[", 
                  RowBox[{
                   RowBox[{"newCenter", "+", 
                    RowBox[{"newRadius", " ", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Cos", "[", "t", "]"}], ",", 
                    RowBox[{"Sin", "[", "t", "]"}]}], "}"}]}]}], ",", 
                   RowBox[{"{", 
                    RowBox[{"t", ",", "0", ",", 
                    RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
                   RowBox[{"PlotStyle", "\[Rule]", 
                    RowBox[{"{", "Red", "}"}]}]}], "]"}]}], "]"}]}], 
              "]"}]}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{
             RowBox[{"-", "n"}], "/", "2"}], ",", 
            RowBox[{"n", "/", "2"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Mostrar", " ", "todas", " ", "las", " ", "geod\[EAcute]sicas", " ", 
         "juntas", " ", "en", " ", "el", " ", "disco"}], "*)"}], 
       RowBox[{"Show", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"mainGeodesic", ",", "parallels", ",", 
           RowBox[{"Graphics", "[", 
            RowBox[{"{", 
             RowBox[{"Circle", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "0"}], "}"}], ",", "1"}], "]"}], "}"}], 
            "]"}]}], "}"}], ",", 
         RowBox[{"PlotRange", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1.1"}], ",", "1.1"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1.1"}], ",", "1.1"}], "}"}]}], "}"}]}], ",", 
         RowBox[{"Axes", "\[Rule]", "False"}], ",", 
         RowBox[{"AspectRatio", "\[Rule]", "1"}]}], "]"}]}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Ejemplo", " ", "de", " ", 
     RowBox[{"uso", ":"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"GeodesicasPoincareDisco", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0.5", ",", "0.3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "0.5"}], ",", "0.3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0.7"}], "}"}], ",", "5"}], "]"}], "\n"}]}]], "Input",\

 CellChangeTimes->{{3.952941346580276*^9, 3.95294134714858*^9}}],

