Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Distancia", " ", "en", " ", "el", " ", "Disco", " ", "de", " ", 
    "Poincar\[EAcute]"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"poincareMetric", "[", 
     RowBox[{
      RowBox[{"u_", "?", "VectorQ"}], ",", 
      RowBox[{"v_", "?", "VectorQ"}]}], "]"}], ":=", 
    RowBox[{"Abs", "[", 
     RowBox[{"ArcCosh", "[", 
      RowBox[{"1", "+", 
       RowBox[{"2", " ", 
        RowBox[{
         RowBox[{"SquaredEuclideanDistance", "[", 
          RowBox[{"u", ",", "v"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"u", ".", "u"}]}], ")"}], " ", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
