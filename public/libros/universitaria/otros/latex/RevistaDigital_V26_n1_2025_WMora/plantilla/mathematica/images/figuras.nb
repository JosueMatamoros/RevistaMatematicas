Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"GeodesicasPoincare", "[", 
     RowBox[{"P1_", ",", "P2_", ",", "P3_", ",", "n_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "x1", ",", "y1", ",", "x2", ",", "y2", ",", "x3", ",", "y3", ",", 
        "center", ",", "radius", ",", "mainGeodesic", ",", "parallels", ",", 
        "delta"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{"Coordenadas", " ", "de", " ", "los", " ", "puntos"}], "*)"}], 
      
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x1", ",", "y1"}], "}"}], "=", "P1"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x2", ",", "y2"}], "}"}], "=", "P2"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x3", ",", "y3"}], "}"}], "=", "P3"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Calcular", " ", "el", " ", "centro", " ", "y", " ", "radio", " ", 
         "de", " ", "la", " ", "circunferencia", " ", "ortogonal", " ", "al", 
         " ", "eje", " ", "x", " ", "que", " ", "pasa", " ", "por", " ", "P1",
          " ", "y", " ", "P2"}], "*)"}], 
       RowBox[{"center", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x1", "^", "2"}], "-", 
           RowBox[{"x2", "^", "2"}], "+", 
           RowBox[{"y1", "^", "2"}], "-", 
           RowBox[{"y2", "^", "2"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{"x1", "-", "x2"}], ")"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"radius", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"x1", "-", "center"}], ")"}], "^", "2"}], "+", 
          RowBox[{"y1", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Geod\[EAcute]sica", " ", 
         RowBox[{"principal", ":", 
          RowBox[{"Negra", " ", "y", " ", "gruesa"}]}]}], "*)"}], 
       RowBox[{"mainGeodesic", "=", 
        RowBox[{"ParametricPlot", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"center", "+", 
             RowBox[{"radius", " ", 
              RowBox[{"Cos", "[", "t", "]"}]}]}], ",", 
            RowBox[{"radius", " ", 
             RowBox[{"Sin", "[", "t", "]"}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", 
            RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
          RowBox[{"PlotStyle", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{"Thick", ",", "Black"}], "}"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Generar", " ", "las", " ", "geod\[EAcute]sicas", " ", "paralelas", 
         " ", "que", " ", "pasan", " ", "por", " ", "P3"}], "*)"}], 
       RowBox[{"delta", "=", "0.5"}], ";", 
       RowBox[{"(*", 
        RowBox[{
        "Separaci\[OAcute]n", " ", "entre", " ", "geod\[EAcute]sicas", " ", 
         "paralelas"}], "*)"}], 
       RowBox[{"parallels", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"newP1", ",", "newCenter", ",", "newRadius"}], "}"}], 
            ",", 
            RowBox[{
             RowBox[{"newP1", "=", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"x3", "+", 
                 RowBox[{"k", " ", "delta"}]}], ",", "y3"}], "}"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"newCenter", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"newP1", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "^", "2"}], "-", 
                 RowBox[{"x2", "^", "2"}], "+", 
                 RowBox[{
                  RowBox[{"newP1", "[", 
                   RowBox[{"[", "2", "]"}], "]"}], "^", "2"}], "-", 
                 RowBox[{"y2", "^", "2"}]}], ")"}], "/", 
               RowBox[{"(", 
                RowBox[{"2", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"newP1", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "-", "x2"}], ")"}]}], 
                ")"}]}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"newRadius", "=", 
              RowBox[{"Sqrt", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"newP1", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "-", "newCenter"}], ")"}],
                  "^", "2"}], "+", 
                RowBox[{
                 RowBox[{"newP1", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], "^", "2"}]}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"ParametricPlot", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"newCenter", "+", 
                  RowBox[{"newRadius", " ", 
