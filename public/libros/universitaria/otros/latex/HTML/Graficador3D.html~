<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Graficador 3D — z = f(x,y)</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- Plotly para la superficie 3D -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/plotly.js/2.27.0/plotly.min.js"></script>
  <!-- math.js para evaluar f(x,y) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjs/13.0.3/math.min.js"></script>

  <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  GRAFICADOR 3D  z = f(x,y)  — prefijo .g3-                 ║
    ║  Motor: Plotly.js (WebGL surface)                           ║
    ║  Evaluador: math.js                                         ║
    ╚══════════════════════════════════════════════════════════════╝
  -->
  <style>
    /* ── reset dentro del widget ── */
    .g3-widget *, .g3-widget *::before, .g3-widget *::after {
      box-sizing: border-box; margin: 0; padding: 0;
    }

    /* ── widget raíz ── */
    .g3-widget {
      --g3-bg:      #1a3a52;
      --g3-darker:  #0f2233;
      --g3-mid:     #1e4560;
      --g3-lt:      #2a5a7a;
      --g3-teal:    #b0ffff;
      --g3-gold:    #c8922a;
      --g3-gold-lt: #e8b84b;
      --g3-accent:  #fdb851;
      --g3-error:   #ff6b6b;
      --g3-ink:     #0d1117;

      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      color: #fff;
      background: var(--g3-bg);
      border-radius: 8px;
      box-shadow: 0 6px 40px rgba(0,0,0,.32);
      overflow: hidden;
      width: 100%;
      max-width: 760px;
      margin: 0 auto;
      border: 2px solid var(--g3-darker);
      animation: g3-pop .32s ease both;
    }
    @keyframes g3-pop {
      from { opacity:0; transform:translateY(8px); }
      to   { opacity:1; transform:translateY(0); }
    }

    /* ── header ── */
    .g3-header {
      background: var(--g3-darker);
      padding: .65rem 1.2rem;
      border-bottom: 1px solid var(--g3-lt);
      display: flex; align-items: baseline; gap: .75rem;
    }
    .g3-header h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.05rem; font-weight: 400; color: var(--g3-teal);
    }
    .g3-header span {
      font-family: 'DM Mono', monospace; font-size: .58rem;
      letter-spacing: .12em; text-transform: uppercase; color: var(--g3-gold-lt);
    }

    /* ── área Plotly ── */
    .g3-plot-wrap {
      position: relative; width: 100%;
      background: #ffffff;
      border-bottom: 1px solid var(--g3-lt);
    }
    #g3-plot {
      width: 100%; height: 420px;
    }

    /* overlay "sin gráfico" */
    .g3-empty {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 8px;
      pointer-events: none; transition: opacity .35s;
    }
    .g3-empty-icon { font-size: 3rem; opacity: .12; }
    .g3-empty p {
      font-family: 'DM Mono', monospace; font-size: .7rem;
      letter-spacing: .06em; color: rgba(26,58,82,.35);
    }

    /* ── panel ── */
    .g3-panel {
      background: var(--g3-bg);
      padding: .75rem 1.1rem;
      border-top: 1px solid var(--g3-lt);
      display: flex; flex-direction: column; gap: .6rem;
    }

    /* fila expresión */
    .g3-input-row {
      display: flex; align-items: center; gap: .5rem;
    }
    .g3-fn-label {
      font-family: 'DM Mono', monospace; font-size: .82rem;
      color: var(--g3-teal); white-space: nowrap; flex-shrink: 0;
    }
    .g3-expr {
      flex: 1; padding: .38rem .6rem;
      font-family: 'DM Mono', monospace; font-size: .88rem;
      color: var(--g3-ink); background: #fff;
      border: 2px solid transparent; border-radius: 3px; outline: none;
      transition: border-color .15s;
    }
    .g3-expr:focus  { border-color: var(--g3-accent); }
    .g3-expr.g3-err { border-color: var(--g3-error); color: #8a0000; }

    /* botones */
    .g3-btn-row { display: flex; gap: .4rem; flex-wrap: wrap; align-items: center; }

    .g3-btn {
      padding: .38rem .9rem;
      font-family: 'DM Mono', monospace; font-size: .78rem; font-weight: 700;
      color: #002800; background: var(--g3-accent);
      border: none; border-radius: 3px; cursor: pointer;
      transition: background .14s, transform .08s;
    }
    .g3-btn:hover  { background: #fec96a; }
    .g3-btn:active { transform: scale(.96); }
    .g3-btn.clr    { background: #2a3a4a; color: var(--g3-teal); border: 1px solid #3a5a7a; }
    .g3-btn.clr:hover  { background: #3a5a7a; }
    .g3-btn.help   { background: var(--g3-lt); color: var(--g3-teal); border: 1px solid #3a7aaa; }
    .g3-btn.help:hover { background: #3a7aaa; }
    .g3-btn.exp-png { background: #2e6e4a; color: #fff; }
    .g3-btn.exp-png:hover { background: #3a8a5c; }

    /* select */
    .g3-select {
      padding: .32rem .5rem;
      font-family: 'DM Mono', monospace; font-size: .78rem;
      color: var(--g3-ink); background: #fff;
      border: 2px solid transparent; border-radius: 3px;
      outline: none; cursor: pointer; transition: border-color .15s;
    }
    .g3-select:focus { border-color: var(--g3-accent); }

    /* sliders */
    .g3-scale-row { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; }
    .g3-scale-field { display: flex; align-items: center; gap: .45rem; }
    .g3-scale-lbl { font-family: 'DM Mono', monospace; font-size: .62rem; color: rgba(176,255,255,.5); white-space: nowrap; }
    .g3-slider    { flex: 1; accent-color: var(--g3-accent); }
    .g3-scale-val { font-family: 'DM Mono', monospace; font-size: .7rem; color: var(--g3-gold-lt); min-width: 1.8rem; text-align: right; }

    /* rangos xy */
    .g3-range-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: .5rem;
    }
    .g3-range-field { display: flex; flex-direction: column; gap: .2rem; }
    .g3-range-lbl { font-family: 'DM Mono', monospace; font-size: .62rem; color: rgba(176,255,255,.5); }
    .g3-num {
      padding: .3rem .45rem;
      font-family: 'DM Mono', monospace; font-size: .78rem;
      color: var(--g3-ink); background: #fff;
      border: 2px solid transparent; border-radius: 3px; outline: none;
      width: 100%; transition: border-color .15s;
    }
    .g3-num:focus { border-color: var(--g3-accent); }

    /* separador */
    .g3-sep { border: none; border-top: 1px solid rgba(176,255,255,.12); margin: .05rem 0; }

    /* etiqueta de fila */
    .g3-row-label {
      font-family: 'DM Mono', monospace; font-size: .65rem;
      color: rgba(176,255,255,.45); white-space: nowrap; letter-spacing: .06em;
    }

    /* ejemplos chips */
    .g3-chips { display: flex; flex-wrap: wrap; gap: .35rem; }
    .g3-chip {
      background: rgba(200,146,42,.13);
      border: 1px solid rgba(200,146,42,.35);
      color: var(--g3-gold-lt);
      font-family: 'DM Mono', monospace; font-size: .68rem;
      padding: .18rem .55rem; border-radius: 20px;
      cursor: pointer; transition: background .15s, color .15s;
      white-space: nowrap;
    }
    .g3-chip:hover { background: rgba(200,146,42,.28); color: var(--g3-accent); }

    /* mensaje error */
    .g3-msg {
      font-family: 'DM Mono', monospace; font-size: .68rem;
      color: var(--g3-error); min-height: .85rem; letter-spacing: .04em;
    }

    /* ── panel ayuda ── */
    .g3-help-panel {
      display: none;
      background: var(--g3-darker); border-top: 1px solid var(--g3-lt);
      padding: .7rem 1.1rem; max-height: 240px; overflow-y: auto;
    }
    .g3-help-panel.open { display: block; }
    .g3-help-panel h3 {
      font-family: 'DM Mono', monospace; font-size: .65rem;
      letter-spacing: .12em; text-transform: uppercase;
      color: var(--g3-gold-lt); margin-bottom: .4rem; margin-top: .55rem;
    }
    .g3-help-panel h3:first-child { margin-top: 0; }
    .g3-help-panel table { width: 100%; border-collapse: collapse; font-family: 'DM Mono', monospace; font-size: .68rem; }
    .g3-help-panel td { padding: .1rem .5rem; vertical-align: top; color: rgba(176,255,255,.75); }
    .g3-help-panel td:first-child { color: var(--g3-teal); width: 40%; }

    /* ── footer widget ── */
    .g3-footer {
      padding: .38rem 1.2rem; border-top: 1px solid var(--g3-darker);
      font-family: 'DM Mono', monospace; font-size: .58rem;
      letter-spacing: .1em; color: rgba(176,255,255,.25); text-align: right;
    }

    /* checkbox inline */
    .g3-chk-row {
      display: flex; align-items: center; gap: .5rem;
      font-family: 'DM Mono', monospace; font-size: .72rem;
      color: rgba(176,255,255,.6); cursor: pointer;
    }
    input[type="checkbox"] { accent-color: var(--g3-accent); cursor: pointer; }

    /* loading spinner sobre plot */
    .g3-loading {
      position: absolute; inset: 0; background: rgba(255,255,255,0.82);
      display: none; align-items: center; justify-content: center;
      font-family: 'DM Mono', monospace; font-size: .78rem; color: #1a3a52;
      letter-spacing: .1em; pointer-events: none;
    }
    .g3-loading.show { display: flex; }
  </style>

  <!-- ── TEC PAGE STYLES ── -->
  <style>
    :root {
      --tec-bg:      #f0ede8;
      --tec-ink:     #0d1117;
      --tec-accent:  #1a4f8a;
      --tec-gold:    #c8922a;
      --tec-gold-lt: #e8b84b;
      --tec-rule:    #d4cfc9;
      --tec-muted:   #7a7269;
      --tec-info-bg: #eef3fb;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --tec-bg:      #0d1117;
        --tec-ink:     #e4dfd8;
        --tec-accent:  #4a9ade;
        --tec-rule:    #1e2d3d;
        --tec-muted:   #8a8279;
        --tec-info-bg: #0f2035;
      }
    }
    html { font-size: 16px; }
    body {
      margin: 0;
      background: var(--tec-bg);
      color: var(--tec-ink);
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem; line-height: 1.6;
      min-height: 100vh; padding: 1.5rem 0 2rem;
    }
    .tec-page {
      max-width: 880px; margin: 0 auto; padding: 0 1.25rem;
      display: flex; flex-direction: column; gap: 1.5rem;
    }
    .tec-header { border-bottom: 2px solid var(--tec-gold); padding-bottom: .75rem; }
    .tec-eyebrow {
      font-family: 'DM Mono', monospace; font-size: .7rem;
      letter-spacing: .2em; text-transform: uppercase; color: var(--tec-muted); margin: 0 0 .2rem;
    }
    .tec-course-title {
      font-family: 'DM Serif Display', serif; font-size: 1.5rem;
      font-weight: 400; margin: 0; line-height: 1.2; color: var(--tec-ink);
    }
    .tec-course-link {
      color: var(--tec-accent); text-decoration: none;
      border-bottom: 1px solid transparent; transition: border-color .2s;
    }
    .tec-course-link:hover { border-bottom-color: var(--tec-accent); }
    .tec-info {
      background: var(--tec-info-bg); border: 1px solid var(--tec-rule);
      border-radius: 6px; overflow: hidden;
    }
    .tec-info-toggle {
      width: 100%; padding: .75rem 1.1rem; background: none; border: none;
      cursor: pointer; display: flex; align-items: center; gap: .55rem;
      font-family: 'DM Mono', monospace; font-size: .78rem; letter-spacing: .1em;
      text-transform: uppercase; color: var(--tec-accent); text-align: left;
      transition: background .2s;
    }
    .tec-info-toggle:hover { background: rgba(26,79,138,.07); }
    .tec-info-icon { display: inline-block; transition: transform .22s; font-size: .6rem; }
    .tec-info-toggle[aria-expanded="true"] .tec-info-icon { transform: rotate(90deg); }
    .tec-info-body {
      padding: 1rem 1.1rem 1.2rem; border-top: 1px solid var(--tec-rule);
      display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.25rem;
    }
    @media (max-width: 640px) { .tec-info-body { grid-template-columns: 1fr; } }
    [hidden] { display: none !important; }
    .tec-info-body h3 {
      font-family: 'DM Mono', monospace; font-size: .66rem; letter-spacing: .14em;
      text-transform: uppercase; color: var(--tec-gold); margin: 0 0 .45rem;
    }
    .tec-info-body p, .tec-info-body li {
      font-size: .88rem; color: var(--tec-ink); line-height: 1.65;
    }
    .tec-info-body ol, .tec-info-body ul { padding-left: 1.1rem; margin: 0; }
    .tec-info-body li { margin-bottom: .3rem; }
    .home-footer {
      border-top: 1px solid var(--tec-rule); padding: .85rem 0;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: .5rem;
      font-family: 'DM Mono', monospace; font-size: .72rem; letter-spacing: .08em;
    }
    .footer-brand { color: var(--tec-muted); text-transform: uppercase; }
    .footer-link  { color: var(--tec-accent); text-decoration: none; transition: color .2s; }
    .footer-link:hover { color: var(--tec-gold-lt); }
    @media (max-width: 720px) {
      body { padding: 0.75rem 0 1.5rem; }
      .tec-page { padding: 0 0.75rem; gap: 1rem; }
      .tec-course-title { font-size: 1rem; }
    }
  </style>
</head>
<body>
<div class="tec-page" role="main">

  <header class="tec-header" role="banner">
    <p class="tec-eyebrow">Instituto Tecnológico de Costa Rica · Escuela de Matemática</p>
    <h1 class="tec-course-title">
      <a class="tec-course-link"
         href="https://tecdigital.tec.ac.cr/servicios/revistamatematica/libros/"
         target="_blank">
        Cálculo Diferencial e Integral (2026)
      </a>
    </h1>
  </header>

  <!-- instrucciones -->
  <section class="tec-info" aria-label="Información de la herramienta">
    <button class="tec-info-toggle" id="info-toggle" aria-expanded="false" aria-controls="info-g3">
      <span class="tec-info-icon">▶</span>
      Instrucciones y ejemplos
    </button>
    <div class="tec-info-body" id="info-g3" hidden>
      <div>
        <h3>Propósito</h3>
        <p>Graficador de superficies definidas explícitamente por <strong>z = f(x, y)</strong>.
           Permite visualizar superficies cuádricas, paraboloides, ondas, gaussianas y más,
           con rotación y zoom interactivos mediante Plotly.js.</p>
      </div>
      <div>
        <h3>Cómo usar</h3>
        <ol>
          <li>Ingrese la expresión f(x, y) en el campo <em>z =</em>.</li>
          <li>Defina los rangos [xₘᵢₙ, xₘₐₓ] y [yₘᵢₙ, yₘₐₓ].</li>
          <li>Ajuste resolución, paleta y opciones.</li>
          <li>Presione <strong>Graficar</strong> (o Enter).</li>
          <li>Rote con clic+arrastre; zoom con la rueda.</li>
          <li>Exporte la imagen con ⬇ PNG.</li>
        </ol>
      </div>
      <div>
        <h3>Ejemplos sugeridos</h3>
        <ul>
          <li><code>sin(sqrt(x^2+y^2))</code> — sombrero mexicano</li>
          <li><code>x^2 - y^2</code> — silla de montar</li>
          <li><code>exp(-(x^2+y^2)/4)</code> — campana gaussiana</li>
          <li><code>sin(x)*cos(y)</code> — ondas cruzadas</li>
          <li><code>sqrt(x^2+y^2)</code> — cono</li>
          <li><code>(sqrt(x^2+y^2)-2)^2</code> — torus seccionado</li>
          <li><code>1/(x^2+y^2+0.3)</code> — singularidad suavizada</li>
          <li><code>sin(x^2+y^2)</code> — ondas circulares</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       WIDGET 3D
  ══════════════════════════════════════ -->
  <div class="g3-widget" id="g3-widget">

    <div class="g3-header">
      <h2>Graficador 3D de Superficies</h2>
      <span>z = f(x,y) · Plotly.js + math.js</span>
    </div>

    <!-- área de la gráfica Plotly -->
    <div class="g3-plot-wrap">
      <div id="g3-plot"></div>
      <div class="g3-empty" id="g3-empty">
        <div class="g3-empty-icon">🗻</div>
        <p>Ingrese z = f(x,y) y presione Graficar</p>
      </div>
      <div class="g3-loading" id="g3-loading">calculando…</div>
    </div>

    <!-- panel de control -->
    <div class="g3-panel">

      <!-- expresión -->
      <div class="g3-input-row">
        <span class="g3-fn-label">z =</span>
        <input class="g3-expr" id="g3-expr" type="text"
               value="sin(sqrt(x^2+y^2))"
               autocomplete="off" spellcheck="false"
               placeholder="ej: sin(x)*cos(y), x^2-y^2, exp(-(x^2+y^2)/4)">
      </div>

      <!-- ejemplos -->
      <div class="g3-chips" id="g3-chips"></div>

      <hr class="g3-sep">

      <!-- rangos x, y -->
      <div class="g3-btn-row" style="align-items:center; gap:.3rem; flex-wrap:wrap;">
        <span class="g3-row-label">Rango x:</span>
        <input class="g3-num" id="g3-xmin" type="number" value="-6" step="0.5" style="width:62px">
        <span class="g3-row-label">a</span>
        <input class="g3-num" id="g3-xmax" type="number" value="6"  step="0.5" style="width:62px">
        <span class="g3-row-label" style="margin-left:.6rem;">Rango y:</span>
        <input class="g3-num" id="g3-ymin" type="number" value="-6" step="0.5" style="width:62px">
        <span class="g3-row-label">a</span>
        <input class="g3-num" id="g3-ymax" type="number" value="6"  step="0.5" style="width:62px">
      </div>

      <hr class="g3-sep">

      <!-- resolución y paleta -->
      <div class="g3-scale-row">
        <div class="g3-scale-field">
          <span class="g3-scale-lbl">Resolución</span>
          <input class="g3-slider" id="g3-res" type="range" min="15" max="100" value="55">
          <span class="g3-scale-val" id="g3-res-v">55</span>
        </div>
        <div class="g3-scale-field" style="gap:.45rem;">
          <span class="g3-scale-lbl">Paleta</span>
          <select class="g3-select" id="g3-palette">
            <option value="Viridis"  selected>Viridis</option>
            <option value="Plasma">Plasma</option>
            <option value="Turbo">Turbo</option>
            <option value="RdBu">RdBu (div.)</option>
            <option value="Hot">Hot</option>
            <option value="Electric">Electric</option>
            <option value="Cividis">Cividis</option>
            <option value="Jet">Jet</option>
          </select>
        </div>
      </div>

      <hr class="g3-sep">

      <!-- rango z + primer octante -->
      <div class="g3-btn-row" style="align-items:flex-end; gap:.35rem; flex-wrap:wrap;">
        <span class="g3-row-label" style="align-self:center;">Clip z:</span>
        <div class="g3-range-field">
          <span class="g3-range-lbl">z mín</span>
          <input class="g3-num" id="g3-zclipmin" type="number" step="0.5"
                 placeholder="−∞" style="width:62px;">
        </div>
        <div class="g3-range-field">
          <span class="g3-range-lbl">z máx</span>
          <input class="g3-num" id="g3-zclipmax" type="number" step="0.5"
                 placeholder="+∞" style="width:62px;">
        </div>
        <label class="g3-chk-row" style="margin-left:.4rem; align-self:center;">
          <input type="checkbox" id="g3-octante"> primer octante
        </label>
      </div>

      <hr class="g3-sep">

      <!-- opciones -->
      <div class="g3-btn-row" style="flex-wrap:wrap; gap:.7rem;">
        <span class="g3-row-label">Opciones:</span>
        <label class="g3-chk-row">
          <input type="checkbox" id="g3-wire"> malla sup.
        </label>
        <label class="g3-chk-row">
          <input type="checkbox" id="g3-contour"> curvas z=c
        </label>
        <label class="g3-chk-row">
          <input type="checkbox" id="g3-axes" checked> ejes XYZ
        </label>
      </div>

      <hr class="g3-sep">

      <!-- plano: un solo campo de texto -->
      <div>
        <div class="g3-btn-row" style="align-items:center; gap:.5rem; margin-bottom:.3rem;">
          <span class="g3-row-label">Plano:</span>
          <label class="g3-chk-row">
            <input type="checkbox" id="g3-plane"> mostrar
          </label>
        </div>
        <input class="g3-expr" id="g3-plane-expr" type="text"
               placeholder="x + 2y − z = 1  ó  1, 2, −1, 1"
               autocomplete="off" spellcheck="false">
        <div id="g3-plane-preview"
             style="font-family:'DM Mono',monospace;font-size:.68rem;
                    color:#1a8c2e;min-height:.9rem;margin-top:.25rem;
                    letter-spacing:.03em;"></div>
      </div>

      <hr class="g3-sep">

      <!-- punto (a,b,c) -->
      <div class="g3-btn-row" style="align-items:center; gap:.4rem; flex-wrap:wrap;">
