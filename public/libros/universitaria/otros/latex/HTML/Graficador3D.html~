function makeXYgrid(xmin,xmax,ymin,ymax,nx,ny){
  var xs=linspace(xmin,xmax,nx+1);
  var ys=linspace(ymin,ymax,ny+1);
  var gx=[],gy=[],gz=[];
  xs.forEach(function(x){          /* líneas || al eje Y */
    gx.push(x,x,null); gy.push(ymin,ymax,null); gz.push(0,0,null);
  });
  ys.forEach(function(y){          /* líneas || al eje X */
    gx.push(xmin,xmax,null); gy.push(y,y,null); gz.push(0,0,null);
  });
  return {
    type:'scatter3d', mode:'lines',
    x:gx, y:gy, z:gz,
