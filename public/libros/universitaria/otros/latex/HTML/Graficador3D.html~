    xa=[0,0]; ya=[0,0]; za=[zRng[0],zRng[1]];
    /* V en plano XZ: spread en ±X */
    vx=[-s,        0, s       ];
    vy=[0,         0, 0       ];
    vz=[zRng[1]-b, zRng[1], zRng[1]-b];
    lblX=0; lblY=0; lblZ=zRng[1]+span*0.13;
