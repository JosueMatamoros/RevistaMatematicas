var lastLayout   = {};

/* ══════════════════════════════════════════════════════════════════
   marchingSquares(xs, ys, vals, level)
   vals[j][i] = valor en (xs[i], ys[j]).  Devuelve {x,y} con null
   como separador de segmentos.  Usado para curvas de nivel y para
   la intersección plano-superficie.
   ══════════════════════════════════════════════════════════════════ */
function marchingSquares(xs, ys, vals, level){
  var N=xs.length, M=ys.length;
  var rx=[], ry=[];
  for(var j=0;j<M-1;j++){
    for(var i=0;i<N-1;i++){
      var v00=vals[j][i],   v10=vals[j][i+1];
      var v01=vals[j+1][i], v11=vals[j+1][i+1];
      if(v00===null||v10===null||v01===null||v11===null) continue;
      var pts=[];
      function edge(za,zb,xa,xb,ya,yb){
        if((za-level)*(zb-level)<0){
          var t=(level-za)/(zb-za);
          pts.push([xa+t*(xb-xa), ya+t*(yb-ya)]);
        }
      }
      edge(v00,v10, xs[i],xs[i+1], ys[j],ys[j]);
      edge(v10,v11, xs[i+1],xs[i+1], ys[j],ys[j+1]);
      edge(v01,v11, xs[i],xs[i+1], ys[j+1],ys[j+1]);
      edge(v00,v01, xs[i],xs[i], ys[j],ys[j+1]);
      if(pts.length>=2){
        rx.push(pts[0][0], pts[1][0], null);
        ry.push(pts[0][1], pts[1][1], null);
      }
    }
  }
  return {x:rx, y:ry};
}

/* ── Curvas de nivel z=c proyectadas en el plano z=0 ── */
function makeContoursTrace(xs, ys, zs, zMin, zMax, nLev){
  var levels=linspace(zMin+(zMax-zMin)*0.05, zMax-(zMax-zMin)*0.05, nLev);
  var allX=[], allY=[], allZ=[];
  levels.forEach(function(lv){
    var seg=marchingSquares(xs, ys, zs, lv);
    for(var k=0;k<seg.x.length;k++){
      allX.push(seg.x[k]); allY.push(seg.y[k]);
      allZ.push(seg.x[k]===null ? null : 0);
    }
  });
  return {
    type:'scatter3d', mode:'lines',
    x:allX, y:allY, z:allZ,
    line:{ color:'rgba(30,80,200,0.65)', width:2 },
    showlegend:false, hoverinfo:'none', name:'curvas-z'
  };
}

/* ── Plano ax+by+cz=d como mesh3d (sin heredar iluminación) ── */
function makePlaneTrace(xmin,xmax,ymin,ymax, zRMin,zRMax, a,b,c,d){
  var res=12;
  var X=[],Y=[],Z=[],I=[],J=[],K=[];

  function buildMesh(xArr,yArr,zFn){
    for(var jj=0;jj<yArr.length;jj++)
      for(var ii=0;ii<xArr.length;ii++){
        var zv=zFn(xArr[ii],yArr[jj]);
        X.push(xArr[ii]); Y.push(yArr[jj]); Z.push(zv);
      }
    var R=xArr.length;
    for(var jj=0;jj<yArr.length-1;jj++)
      for(var ii=0;ii<R-1;ii++){
        var idx=jj*R+ii;
        I.push(idx);   J.push(idx+1);   K.push(idx+R);
        I.push(idx+1); J.push(idx+R+1); K.push(idx+R);
      }
  }

  if(Math.abs(c)>1e-10){
    buildMesh(linspace(xmin,xmax,res), linspace(ymin,ymax,res),
              function(xi,yi){ return (d-a*xi-b*yi)/c; });
  } else {
    var norm=Math.sqrt(a*a+b*b);
    if(norm<1e-10) return null;
    var dx=-b/norm, dy=a/norm;
    var x0=a*d/(a*a+b*b), y0=b*d/(a*a+b*b);
    var corners=[[xmin,ymin],[xmax,ymin],[xmin,ymax],[xmax,ymax]];
    var tvs=corners.map(function(q){ return (q[0]-x0)*dx+(q[1]-y0)*dy; });
    var tmin=Math.min.apply(null,tvs), tmax=Math.max.apply(null,tvs);
    var ts=linspace(tmin,tmax,res), zr=linspace(zRMin,zRMax,res);
    for(var jj=0;jj<zr.length;jj++)
      for(var ii=0;ii<ts.length;ii++){
        X.push(x0+ts[ii]*dx); Y.push(y0+ts[ii]*dy); Z.push(zr[jj]);
      }
    var R=ts.length;
    for(var jj=0;jj<zr.length-1;jj++)
      for(var ii=0;ii<R-1;ii++){
        var idx=jj*R+ii;
        I.push(idx);   J.push(idx+1);   K.push(idx+R);
        I.push(idx+1); J.push(idx+R+1); K.push(idx+R);
      }
  }
  return {
    type:'mesh3d', x:X, y:Y, z:Z, i:I, j:J, k:K,
    color:'#22bb66', opacity:0.42,
    flatshading:false,
    lighting:{ ambient:0.95, diffuse:0.05, specular:0, roughness:1, fresnel:0 },
    lightposition:{ x:0, y:0, z:1e5 },
    showlegend:false, hoverinfo:'none', name:'plano'
  };
}

/* ── parsePlaneExpr: acepta "ax+by+cz=d" o "a,b,c,d" ──────────
   Formatos soportados:
     "1, 2, -1, 3"        → [1, 2, -1, 3]
     "x + 2y - z = 3"     → [1, 2, -1, 3]
     "2x - 3z = 0"        → [2, 0, -3, 0]
     "-y + z = 1"         → [0,-1, 1, 1]
   ─────────────────────────────────────────────────────────────── */
function parsePlaneExpr(s){
  s = s.replace(/−/g,'-').trim();   /* normalizar guion largo */

  /* Formato 1: cuatro números separados por comas/punto y coma/espacios */
  var parts = s.replace(/=/g,' ').trim().split(/[\s,;]+/).filter(Boolean);
  if(parts.length===4){
    var ns=parts.map(Number);
    if(!ns.some(isNaN)) return ns;
  }

  /* Formato 2: ecuación "lhs = d" */
  var eqIdx=s.indexOf('=');
  if(eqIdx<0) return null;
  var lhs=s.substring(0,eqIdx).trim();
  var dd=parseFloat(s.substring(eqIdx+1).trim());
  if(isNaN(dd)) return null;

  function coef(v){
    /* captura el coeficiente de x, y, z en la expresión lhs */
    var re=new RegExp('([+\\-]?\\s*\\d*\\.?\\d*)\\s*\\*?\\s*'+v,'i');
    var m=lhs.match(re);
    if(!m) return 0;
    var c=m[1].replace(/\s/g,'');
    if(c===''||c==='+') return 1;
    if(c==='-') return -1;
    var n=parseFloat(c);
    return isNaN(n)?0:n;
  }
  return [coef('x'), coef('y'), coef('z'), dd];
}

/* ── fmtPlane: formatea [a,b,c,d] como ecuación legible ── */
function fmtPlane(p){
  var terms=[];
  var names=['x','y','z'];
  for(var i=0;i<3;i++){
    if(p[i]===0) continue;
    var c=p[i]===1?'':p[i]===-1?'-':String(p[i]);
    terms.push(c+names[i]);
  }
  if(!terms.length) return '0 = '+p[3];
  return terms.join(' + ').replace(/\+ -/g,'− ')+' = '+p[3];
}

/* ══════════════════════════════════════════════════════════════════
   chainSegments(segs)
   segs = [{x0,y0,x1,y1}, …]  (segmentos sin orden de marchingSquares)
   Devuelve polilíneas ordenadas: array de arrays de [x,y].
   Algoritmo: busca el vecino más cercano a cada extremo; tolerancia ε.
   ══════════════════════════════════════════════════════════════════ */
function chainSegments(segs){
  if(!segs.length) return [];
  var used = new Array(segs.length).fill(false);
  var chains = [];
  var EPS2 = 1e-10;

  function dist2(ax,ay,bx,by){ return (ax-bx)*(ax-bx)+(ay-by)*(ay-by); }

  for(var s=0; s<segs.length; s++){
    if(used[s]) continue;
    /* iniciar nueva cadena con este segmento */
    var chain=[[segs[s].x0,segs[s].y0],[segs[s].x1,segs[s].y1]];
    used[s]=true;
    /* extender hacia el frente */
    var extended=true;
    while(extended){
      extended=false;
      var tail=chain[chain.length-1];
      var best=-1, bd=Infinity, rev=false;
      for(var k=0;k<segs.length;k++){
        if(used[k]) continue;
        var d0=dist2(tail[0],tail[1],segs[k].x0,segs[k].y0);
        var d1=dist2(tail[0],tail[1],segs[k].x1,segs[k].y1);
        if(d0<bd){ bd=d0; best=k; rev=false; }
        if(d1<bd){ bd=d1; best=k; rev=true;  }
      }
      if(best>=0 && bd<EPS2){
        used[best]=true; extended=true;
        chain.push(rev?[segs[best].x0,segs[best].y0]
                      :[segs[best].x1,segs[best].y1]);
      }
    }
    /* extender hacia atrás */
    extended=true;
    while(extended){
      extended=false;
      var head=chain[0];
      var best=-1, bd=Infinity, rev=false;
      for(var k=0;k<segs.length;k++){
        if(used[k]) continue;
        var d0=dist2(head[0],head[1],segs[k].x0,segs[k].y0);
        var d1=dist2(head[0],head[1],segs[k].x1,segs[k].y1);
        if(d0<bd){ bd=d0; best=k; rev=true;  }
        if(d1<bd){ bd=d1; best=k; rev=false; }
      }
      if(best>=0 && bd<EPS2){
        used[best]=true; extended=true;
        chain.unshift(rev?[segs[best].x1,segs[best].y1]
                         :[segs[best].x0,segs[best].y0]);
      }
    }
    chains.push(chain);
  }
  return chains;
}

/* ── marchingSquaresSegs: igual que marchingSquares pero devuelve
   array de {x0,y0,x1,y1} en vez de listas con null ── */
function marchingSquaresSegs(xs, ys, vals, level){
  var N=xs.length, M=ys.length;
  var segs=[];
  for(var j=0;j<M-1;j++){
    for(var i=0;i<N-1;i++){
      var v00=vals[j][i],   v10=vals[j][i+1];
      var v01=vals[j+1][i], v11=vals[j+1][i+1];
      if(v00===null||v10===null||v01===null||v11===null) continue;
      var pts=[];
      function edge(za,zb,xa,xb,ya,yb){
        if((za-level)*(zb-level)<0){
          var t=(level-za)/(zb-za);
          pts.push([xa+t*(xb-xa), ya+t*(yb-ya)]);
        }
      }
      edge(v00,v10, xs[i],xs[i+1], ys[j],ys[j]);
      edge(v10,v11, xs[i+1],xs[i+1], ys[j],ys[j+1]);
      edge(v01,v11, xs[i],xs[i+1], ys[j+1],ys[j+1]);
      edge(v00,v01, xs[i],xs[i], ys[j],ys[j+1]);
      if(pts.length>=2) segs.push({x0:pts[0][0],y0:pts[0][1],x1:pts[1][0],y1:pts[1][1]});
    }
  }
  return segs;
}

/* ── Intersección plano ax+by+cz=d con z=f(x,y) ──────────────────
   g(x,y) = ax + by + c·f(x,y) − d = 0
   1. Marching squares sobre g → segmentos en XY
   2. Encadenar en polilíneas ordenadas (chainSegments)
   3. Elevar cada punto a z=f(x,y) → curva en la superficie
   4. Proyectar en z=0 → sombra en el plano XY
   ─────────────────────────────────────────────────────────────── */
function makeIntersectionTrace(xs, ys, zs, compiled, a, b, c, d){
  /* grilla de g(x,y) */
  var M=ys.length, N=xs.length, gs=[];
  for(var j=0;j<M;j++){
    var row=[];
    for(var i=0;i<N;i++){
      if(zs[j][i]===null){ row.push(null); continue; }
      row.push(a*xs[i] + b*ys[j] + c*zs[j][i] - d);
    }
    gs.push(row);
  }

  var rawSegs = marchingSquaresSegs(xs, ys, gs, 0);
  var chains  = chainSegments(rawSegs);

  /* construir trazas: segmentos separados por null entre cadenas */
  var cx=[],cy=[],cz=[];   /* curva sobre la sup. */
  var px=[],py=[],pz=[];   /* proyección en z=0   */

  chains.forEach(function(ch, idx){
    if(idx>0){ cx.push(null);cy.push(null);cz.push(null);
               px.push(null);py.push(null);pz.push(null); }
    ch.forEach(function(pt){
      var ex=pt[0], ey=pt[1], ez=null;
      try{ var v=compiled.evaluate({x:ex,y:ey});
           if(isFinite(v)) ez=v; }catch(e){}
      cx.push(ex); cy.push(ey); cz.push(ez);
      px.push(ex); py.push(ey); pz.push(0);
    });
  });

  var traceOnSurf={
    type:'scatter3d', mode:'lines',
    x:cx, y:cy, z:cz,
    line:{ color:'#d04000', width:5 },
    showlegend:false, hoverinfo:'none', name:'intersec-sup'
  };
  var traceOnXY={
    type:'scatter3d', mode:'lines',
    x:px, y:py, z:pz,
    line:{ color:'rgba(200,90,0,0.45)', width:2, dash:'dot' },
    showlegend:false, hoverinfo:'none', name:'intersec-xy'
  };
  return [traceOnSurf, traceOnXY];
}

/* ── parsePunto: acepta (a,b,c) o (a;b;c) con o sin paréntesis ── */
function parsePunto(s){
  s = s.replace(/[()[\]{}]/g,'').trim();
  var parts = s.split(/[,;]+/).map(function(p){ return p.trim(); });
  if (parts.length !== 3) return null;
  var nums = parts.map(Number);
  if (nums.some(isNaN)) return null;
  return nums;   /* [a, b, c] */
}

/* ── Graficar ───────────────────────────────────────────────────── */
function graficar(){
  setMsg('');
  setExprError(false);

  var exprStr = document.getElementById('g3-expr').value.trim();
  if (!exprStr){ setMsg('Ingrese una expresión f(x,y).'); setExprError(true); return; }

  var xmin = parseFloat(document.getElementById('g3-xmin').value);
  var xmax = parseFloat(document.getElementById('g3-xmax').value);
  var ymin = parseFloat(document.getElementById('g3-ymin').value);
  var ymax = parseFloat(document.getElementById('g3-ymax').value);

  if (xmin >= xmax){ setMsg('Error: xₘᵢₙ debe ser menor que xₘₐₓ.'); return; }
  if (ymin >= ymax){ setMsg('Error: yₘᵢₙ debe ser menor que yₘₐₓ.'); return; }

  var N       = parseInt(slRes.value, 10);
  var palette = document.getElementById('g3-palette').value;
  var wire    = document.getElementById('g3-wire').checked;
  var contour = document.getElementById('g3-contour').checked;
  var showAxes= document.getElementById('g3-axes').checked;
  var octante = document.getElementById('g3-octante').checked;

  /* z-clip */
  var zClipMinRaw = document.getElementById('g3-zclipmin').value.trim();
  var zClipMaxRaw = document.getElementById('g3-zclipmax').value.trim();
  var zClipMin = zClipMinRaw !== '' ? parseFloat(zClipMinRaw) : -Infinity;
  var zClipMax = zClipMaxRaw !== '' ? parseFloat(zClipMaxRaw) : Infinity;
  if(octante) zClipMin = Math.max(zClipMin, 0);

  /* primer octante: forzar xmin,ymin ≥ 0 */
  var xminEff = octante ? Math.max(0, xmin) : xmin;
  var yminEff = octante ? Math.max(0, ymin) : ymin;

  /* compilar expresión */
  var compiled;
  try {
    compiled = math.compile(exprStr);
  } catch(err){
    setMsg('Sintaxis: ' + err.message.split('\n')[0]);
    setExprError(true); return;
  }

  /* mostrar loading */
  document.getElementById('g3-loading').classList.add('show');

  setTimeout(function(){
    var xs = linspace(xminEff, xmax, N);
    var ys = linspace(yminEff, ymax, N);
    var zs = [];
    var zMin = Infinity, zMax = -Infinity;

    try {
      for (var j=0; j<N; j++){
        var row = [];
        for (var i=0; i<N; i++){
          var val = compiled.evaluate({ x: xs[i], y: ys[j] });
          if (isFinite(val) && val >= zClipMin && val <= zClipMax){
            row.push(val);
            if (val < zMin) zMin = val;
            if (val > zMax) zMax = val;
          } else {
            row.push(null);
          }
        }
        zs.push(row);
      }
    } catch(err){
      document.getElementById('g3-loading').classList.remove('show');
      setMsg('Error al evaluar: ' + err.message.split('\n')[0]);
      setExprError(true); return;
    }

    /* si no hay datos finitos */
    if (!isFinite(zMin)){ zMin = -1; zMax = 1; }

    /* ── contornos sobre la superficie (solo malla, si está activo) ── */
    var contours3d = {
      x:{ show: wire, color:'rgba(40,40,40,0.18)', width:1 },
      y:{ show: wire, color:'rgba(40,40,40,0.18)', width:1 },
      z:{ show: false }
    };

    /* ── traza superficie ── */
    var traceSurf = {
      type: 'surface',
      x: xs, y: ys, z: zs,
      colorscale: palette,
      contours: contours3d,
      opacity: 0.92,
      lighting:{ ambient:0.55, diffuse:0.8, specular:0.25, roughness:0.4, fresnel:0.2 },
      showscale: true,
      colorbar:{
        thickness:13, len:0.55,
        tickfont:{ color:'#334', size:9, family:'DM Mono, monospace' },
        outlinecolor:'rgba(0,0,0,0.18)',
        bgcolor:'rgba(255,255,255,0.7)'
      },
      name: 'z = ' + exprStr
    };

    /* ── trazas ── */
    var traces = [traceSurf];

    /* curvas de nivel z=c proyectadas en z=0 (marching squares) */
    if(contour) traces.push(makeContoursTrace(xs, ys, zs, zMin, zMax, 12));

    /* cuadrícula XY en z=0 */
    var nGrid = Math.round(Math.min(Math.max((xmax-xmin)*1.5, 8), 14));
    traces.push(makeXYgrid(xmin,xmax,ymin,ymax, nGrid, nGrid));

    /* ejes */
    if (showAxes){
      var zRng = [zMin, zMax];
      traces = traces.concat(
        makeAxis('x', [xmin,xmax], zRng),
        makeAxis('y', [ymin,ymax], zRng),
        makeAxis('z', [xmin,xmax], zRng)
      );
    }

    /* plano ax+by+cz=d + intersección */
    var showPlane = document.getElementById('g3-plane').checked;
    if(showPlane){
      var planeStr = document.getElementById('g3-plane-expr').value.trim();
      var pp = parsePlaneExpr(planeStr);
      if(pp && (pp[0]!==0||pp[1]!==0||pp[2]!==0)){
        var pa=pp[0], pb=pp[1], pc=pp[2], pd=pp[3];
        var zPad2 = Math.max((zMax-zMin)*0.08, 0.2);
        var pt=makePlaneTrace(xminEff,xmax,yminEff,ymax,
                              Math.min(0,zMin)-zPad2, zMax+zPad2,
                              pa,pb,pc,pd);
        if(pt) traces.push(pt);
        traces = traces.concat(makeIntersectionTrace(xs,ys,zs,compiled,pa,pb,pc,pd));
      }
    }

    /* ── punto (a,b,c) si está definido ── */
    var ptStr = document.getElementById('g3-punto').value.trim();
    if (ptStr){
      var pt = parsePunto(ptStr);
      if (pt){
        var pz = pt[2];
        traces.push({
          type:'scatter3d', mode:'lines',
          x:[pt[0],pt[0]], y:[pt[1],pt[1]], z:[0, pz],
          line:{ color:'#333', width:2, dash:'dot' },
          showlegend:false, hoverinfo:'none', name:'pt-line'
        });
        traces.push({
          type:'scatter3d', mode:'markers+text',
          x:[pt[0]], y:[pt[1]], z:[pz],
          marker:{ size:6, color:'#c00', symbol:'circle',
                   line:{ color:'#800', width:1 } },
          text:['('+pt[0]+', '+pt[1]+', '+pt[2]+')'],
          textposition:'top center',
          textfont:{ size:11, color:'#800', family:'DM Mono, monospace' },
          showlegend:false, hoverinfo:'text', name:'punto'
        });
        traces.push({
          type:'scatter3d', mode:'markers',
          x:[pt[0]], y:[pt[1]], z:[0],
          marker:{ size:4, color:'#888', symbol:'circle-open',
                   line:{ color:'#888', width:1.5 } },
          showlegend:false, hoverinfo:'none', name:'pt-proj'
        });
      }
    }

    /* z range: siempre incluye 0 para que la malla XY sea visible */
    var zPad = Math.max((zMax-zMin)*0.08, 0.2);
    var zRangeMin = Math.min(0, zMin) - zPad;
    var zRangeMax = zMax + zPad;

    /* ── layout fondo blanco ── */
    var layout = {
      paper_bgcolor: '#ffffff',
      plot_bgcolor:  '#ffffff',
      margin:{ t:36, b:8, l:8, r:8 },
      scene:{
        bgcolor: '#ffffff',
        xaxis: axStyle('x'),
        yaxis: axStyle('y'),
        zaxis: Object.assign(axStyle('z'), { range:[zRangeMin, zRangeMax] }),
        camera:{ eye:{ x:1.45, y:1.45, z:0.95 } },
        aspectmode: 'auto'
      },
      font:{ family:'DM Sans, sans-serif', color:'#334' },
      title:{
        text: 'z = ' + exprStr,
        font:{ family:'DM Mono, monospace', size:12, color:'#1a3a52' },
        x:0.5, xanchor:'center', y:0.99
      }
    };

    var config = {
      responsive: true,
      displayModeBar: true,
      modeBarButtonsToRemove:['sendDataToCloud','lasso2d','select2d','resetCameraLastSave3d'],
      displaylogo: false
    };

    /* ocultar overlay vacío */
    var emptyEl = document.getElementById('g3-empty');
    emptyEl.style.opacity = '0';
    setTimeout(function(){ emptyEl.style.display='none'; }, 350);

    if (plotRendered){
      Plotly.react('g3-plot', traces, layout, config);
    } else {
      Plotly.newPlot('g3-plot', traces, layout, config);
      plotRendered = true;
    }

    /* guardar trazas y zRng para exportar PNG */
    lastTraces = traces;
    lastLayout = layout;

    document.getElementById('g3-loading').classList.remove('show');

  }, 30);
}

/* ── Limpiar ────────────────────────────────────────────────────── */
function limpiar(){
  Plotly.purge('g3-plot');
  plotRendered = false;
  lastTraces = []; lastLayout = {};
  var emptyEl = document.getElementById('g3-empty');
  emptyEl.style.display = 'flex';
  setTimeout(function(){ emptyEl.style.opacity = '1'; }, 10);
  document.getElementById('g3-expr').value = '';
  setMsg(''); setExprError(false);
}

/* ── Exportar PNG (fondo ya es blanco) ─────────────────────────── */
function exportPNG(){
  if (!plotRendered){ setMsg('Primero genere una gráfica.'); return; }
  setMsg('Generando PNG…');
  Plotly.toImage('g3-plot', {
    format:'png', filename:'superficie3D',
    width:1400, height:1000, scale:2
  }).then(function(dataUrl){
    var a = document.createElement('a');
    a.download = 'superficie3D.png';
    a.href = dataUrl;
    a.click();
    setMsg('');
  }).catch(function(err){
    setMsg('Error al exportar: ' + err.message);
  });
}

/* ── Ayuda ──────────────────────────────────────────────────────── */
document.getElementById('g3-btn-help').addEventListener('click', function(){
  document.getElementById('g3-help').classList.toggle('open');
});

/* ── Eventos ────────────────────────────────────────────────────── */
document.getElementById('g3-btn-plot').addEventListener('click', graficar);
document.getElementById('g3-btn-clr' ).addEventListener('click', limpiar);
document.getElementById('g3-btn-png' ).addEventListener('click', exportPNG);
document.getElementById('g3-expr').addEventListener('keydown', function(e){
  if (e.key === 'Enter') graficar();
});
/* re-renderizar al cambiar paleta, checkboxes */
['g3-palette','g3-wire','g3-contour','g3-axes','g3-plane','g3-octante'].forEach(function(id){
  document.getElementById(id).addEventListener('change', function(){
    if (plotRendered) graficar();
  });
});
/* punto, z-clip con debounce */
var inputDebounce;
['g3-punto','g3-zclipmin','g3-zclipmax'].forEach(function(id){
  document.getElementById(id).addEventListener('input', function(){
    clearTimeout(inputDebounce);
    inputDebounce = setTimeout(function(){ if(plotRendered) graficar(); }, 350);
  });
});
/* plano: live preview + re-render */
var planeDebounce;
document.getElementById('g3-plane-expr').addEventListener('input', function(){
  var pp = parsePlaneExpr(this.value.trim());
  var prev = document.getElementById('g3-plane-preview');
  if(pp){ prev.textContent = fmtPlane(pp); prev.style.color='#1a8c2e'; }
  else   { prev.textContent = this.value.trim()?'formato: x+2y−z=1  ó  1,2,−1,1':''; prev.style.color='#999'; }
  clearTimeout(planeDebounce);
  planeDebounce = setTimeout(function(){
    if(plotRendered && document.getElementById('g3-plane').checked) graficar();
  }, 450);
});

/* ── panel TEC info toggle ──────────────────────────────────────── */
document.getElementById('info-toggle').addEventListener('click', function(){
  var exp = this.getAttribute('aria-expanded') === 'true';
  this.setAttribute('aria-expanded', String(!exp));
  var body = document.getElementById('info-g3');
  if (body) body.hidden = exp;
});

/* ── Render inicial ─────────────────────────────────────────────── */
window.addEventListener('load', function(){
  setTimeout(graficar, 500);
});

}());
