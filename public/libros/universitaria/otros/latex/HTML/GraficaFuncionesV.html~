<footer class="home-footer">
  <span class="footer-brand">Edición LaTeX — Tec</span>
  <a class="footer-link" href="https://tecdigital.tec.ac.cr/servicios/revistamatematica/libros/" target="_blank">Revista Matemática, Educación e Internet</a>
</footer>

</div>

<script>
(function(){
  'use strict';

  /* paleta cgraf — colores de \definecolor{cgrafN} en LaTeX */
  var COLORS = [
    'rgb(35,101,224)',   /* cgraf1  azul intenso   */
    'rgb(165,103,0)',    /* cgraf2  café            */
    'rgb(255,191,0)',    /* cgraf3  amarillo        */
    'rgb(235,98,53)',    /* cgraf4  rojo-anaranjado */
    'rgb(142,124,195)',  /* cgraf5  morado          */
    'rgb(237,125,49)',   /* cgraf6  naranja         */
    'rgb(147,178,195)',  /* cgraf7  azul claro      */
    'rgb(116,179,54)',   /* cgraf8  verde           */
    'rgb(204,102,194)',  /* cgraf9  magenta         */
    'rgb(162,166,0)',    /* cgraf10 verde oliva     */
    'rgb(226,85,54)',    /* cgraf11 rojo            */
    'rgb(96,126,205)',   /* cgraf12 azul medio      */
    'rgb(240,150,17)',   /* cgraf13 naranja oscuro  */
    'rgb(188,91,128)',   /* cgraf14 rosado          */
    'rgb(71,182,109)'    /* cgraf15 verde claro     */
  ];

  var MAX_FNS = 10;

  /* ══════════════════════════════════════
     WIDGET
  ══════════════════════════════════════ */
  function GrafWidget(wid){
    var elExpr   = document.getElementById('gf-expr-'       + wid);
    var elXmin   = document.getElementById('gf-xmin-'       + wid);
    var elXmax   = document.getElementById('gf-xmax-'       + wid);
    var btnPlot  = document.getElementById('gf-plot-'       + wid);
    var btnDel   = document.getElementById('gf-del-'        + wid);
    var btnClr   = document.getElementById('gf-clr-'        + wid);
    var btnHelp  = document.getElementById('gf-help-'       + wid);
    var slSx     = document.getElementById('gf-sx-'         + wid);
    var slSy     = document.getElementById('gf-sy-'         + wid);
    var slSxV    = document.getElementById('gf-sxv-'        + wid);
    var slSyV    = document.getElementById('gf-syv-'        + wid);
    var elFnList = document.getElementById('gf-fnlist-'     + wid);
    var elMsg    = document.getElementById('gf-msg-'        + wid);
    var helpPanel= document.getElementById('gf-help-panel-' + wid);
    var canvas   = document.getElementById('gf-cv-'         + wid);
    var wrap     = document.getElementById('gf-wrap-'       + wid);
    var elCoords = document.getElementById('gf-coords-'     + wid);
    var ctx      = canvas.getContext('2d');

    /* ── estado ── */
    var fns = [];      /* [{expr, xmin, xmax, color, compiled}] */
    var escX = 30, escY = 30;
    var lineW = 2;     /* grosor de línea en px */

    /* pan (traslación con ratón) */
    var panX = 0, panY = 0;          /* desplazamiento en px de canvas */
    var panning = false, panSX, panSY, panX0, panY0;

    /* puntos marcados */
    var puntos = [];   /* [{x, y}] */

    /* ── compilar expresión con math.js ── */
    function compile(expr){
      try {
        var node = math.compile(expr);
        /* test con x=1 */
        node.evaluate({ x: 1 });
        return node;
      } catch(e){
        return null;
      }
    }

    function evalFn(compiled, x){
      try {
        var v = compiled.evaluate({ x: x });
        if (typeof v === 'object' && v.im !== undefined) {
          /* número complejo — solo tomar parte real si im≈0 */
          return Math.abs(v.im) < 1e-10 ? v.re : NaN;
        }
        return typeof v === 'number' ? v : NaN;
      } catch(e){ return NaN; }
    }

    /* ── dibujar canvas ── */
    function draw(){
      var dpr = window.devicePixelRatio || 1;
      var W   = canvas.offsetWidth  || 600;
      var H   = canvas.offsetHeight || 337;
      canvas.width  = W * dpr;
      canvas.height = H * dpr;
      ctx.scale(dpr, dpr);

      /* origen con pan aplicado */
      var x0 = W / 2 + panX, y0 = H / 2 + panY;

      /* fondo */
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, W, H);

      /* grilla tenue */
      ctx.strokeStyle = 'rgba(220,220,220,.8)';
      ctx.lineWidth = 1;
      var stepX = escX, stepY = escY;

      /* grilla: calcular primera línea visible desde el origen desplazado */
      var startGX = x0 % stepX;
      for (var gx = startGX; gx < W; gx += stepX){
        ctx.beginPath(); ctx.moveTo(gx,0); ctx.lineTo(gx,H); ctx.stroke();
      }
      var startGY = y0 % stepY;
      for (var gy = startGY; gy < H; gy += stepY){
        ctx.beginPath(); ctx.moveTo(0,gy); ctx.lineTo(W,gy); ctx.stroke();
      }

      /* ejes */
      ctx.strokeStyle = 'rgba(187,187,187,.9)';
      ctx.lineWidth = 1.5;
      if (x0 >= 0 && x0 <= W){
        ctx.beginPath(); ctx.moveTo(x0,8); ctx.lineTo(x0,H-8); ctx.stroke();
      }
      if (y0 >= 0 && y0 <= H){
        ctx.beginPath(); ctx.moveTo(8,y0); ctx.lineTo(W-8,y0); ctx.stroke();
      }

      /* marcas en ejes */
      ctx.strokeStyle = 'rgba(120,120,120,.8)';
      ctx.lineWidth = 1;
      ctx.fillStyle = 'rgba(80,80,80,.7)';
      ctx.font = '9px DM Mono,monospace';
      ctx.textAlign = 'center';

      /* marcas eje X: recorrer hacia ambos lados desde el origen */
      for (var i = stepX; x0+i < W+stepX || x0-i > -stepX; i += stepX){
        var lbl = Math.round(i/escX * 100)/100;
        if (x0+i >= 0 && x0+i <= W){
          ctx.beginPath(); ctx.moveTo(x0+i,y0-3); ctx.lineTo(x0+i,y0+3); ctx.stroke();
          ctx.fillText(lbl,  x0+i, y0+12);
        }
        if (x0-i >= 0 && x0-i <= W){
          ctx.beginPath(); ctx.moveTo(x0-i,y0-3); ctx.lineTo(x0-i,y0+3); ctx.stroke();
          ctx.fillText(-lbl, x0-i, y0+12);
        }
      }
      ctx.textAlign = 'right';
      for (var j = stepY; y0+j < H+stepY || y0-j > -stepY; j += stepY){
        var lbl2 = Math.round(j/escY * 100)/100;
        if (y0-j >= 0 && y0-j <= H){
          ctx.beginPath(); ctx.moveTo(x0-3,y0-j); ctx.lineTo(x0+3,y0-j); ctx.stroke();
          ctx.fillText(lbl2,  x0-5, y0-j+3);
        }
        if (y0+j >= 0 && y0+j <= H){
          ctx.beginPath(); ctx.moveTo(x0-3,y0+j); ctx.lineTo(x0+3,y0+j); ctx.stroke();
          ctx.fillText(-lbl2, x0-5, y0+j+3);
        }
      }

      /* graficar cada función */
      fns.forEach(function(fn){
        if (!fn.compiled) return;
        var xmin = fn.xmin, xmax = fn.xmax;
        var NPTS = Math.max(600, Math.round((xmax - xmin) * escX * 4));
        var dx   = (xmax - xmin) / NPTS;

        ctx.strokeStyle = fn.color;
        ctx.lineWidth   = lineW;
        ctx.lineJoin    = 'round';
        ctx.beginPath();

        var prevY = null, penDown = false;
        for (var i = 0; i <= NPTS; i++){
          var xv = xmin + i * dx;
          var yv = evalFn(fn.compiled, xv);

          var cx = x0 + xv * escX;
          var cy = y0 - yv * escY;

          if (!isFinite(yv) || isNaN(yv)){
            penDown = false; prevY = null; continue;
          }

          if (prevY !== null && Math.abs(cy - prevY) > H * 1.5){
            penDown = false;
          }

          if (!penDown){ ctx.moveTo(cx, cy); penDown = true; }
          else ctx.lineTo(cx, cy);
          prevY = cy;
        }
        ctx.stroke();
      });

      /* puntos marcados */
      puntos.forEach(function(p){
        var cx = x0 + p.x * escX;
        var cy = y0 - p.y * escY;
        var r  = lineW + 2;
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, 2*Math.PI);
        ctx.fillStyle = '#000';
        ctx.fill();
      });
    }

    /* ── coordenadas al mover el mouse ── */
    function getCoords(e){
      var rect = canvas.getBoundingClientRect();
      var W    = canvas.offsetWidth;
      var H    = canvas.offsetHeight;
      var mx   = (e.clientX - rect.left);
      var my   = (e.clientY - rect.top);
      var x0   = W / 2 + panX, y0 = H / 2 + panY;
      var xv   = (mx - x0) / escX;
      var yv   = (y0 - my) / escY;
      return { x: Math.round(xv*1000)/1000, y: Math.round(yv*1000)/1000 };
    }

    /* ── pan con ratón ── */
    wrap.addEventListener('mousedown', function(e){
      panning = true;
      panSX   = e.clientX; panSY = e.clientY;
      panX0   = panX;      panY0 = panY;
      wrap.style.cursor = 'grabbing';
    });
    window.addEventListener('mousemove', function(e){
      if (panning){
        panX = panX0 + (e.clientX - panSX);
        panY = panY0 + (e.clientY - panSY);
        elCoords.textContent = '';
        draw();
      } else {
        var c = getCoords(e);
        if (wrap.matches(':hover'))
          elCoords.textContent = '(' + c.x + ' ; ' + c.y + ')';
      }
    });
    window.addEventListener('mouseup', function(){
      panning = false;
      wrap.style.cursor = 'crosshair';
    });

    /* pan táctil */
    var tpan = false, tSX, tSY, tpX0, tpY0;
    wrap.addEventListener('touchstart', function(e){
      if (e.touches.length === 1){
        tpan = true;
        tSX = e.touches[0].clientX; tSY = e.touches[0].clientY;
        tpX0 = panX; tpY0 = panY;
        e.preventDefault();
      }
    }, {passive:false});
    wrap.addEventListener('touchmove', function(e){
      if (tpan && e.touches.length === 1){
        panX = tpX0 + (e.touches[0].clientX - tSX);
        panY = tpY0 + (e.touches[0].clientY - tSY);
        draw(); e.preventDefault();
      }
    }, {passive:false});
    wrap.addEventListener('touchend', function(){ tpan = false; });

    /* resetear pan */
    function resetPan(){ panX = 0; panY = 0; draw(); }

    /* ── actualizar lista visual ── */
    function updateFnList(){
      elFnList.innerHTML = '';
      fns.forEach(function(fn, i){
        var item = document.createElement('div');
        item.className = 'gf-fn-item';
        var dot = document.createElement('span');
        dot.className = 'gf-fn-dot';
        dot.style.background = fn.color;
        var expr = document.createElement('span');
        expr.className = 'gf-fn-expr';
        expr.textContent = (i+1) + '. f(x) = ' + fn.expr +
          '   x ∈ [' + fn.xmin + ', ' + fn.xmax + ']';
        item.appendChild(dot);
        item.appendChild(expr);
        elFnList.appendChild(item);
      });
    }

    /* ── graficar ── */
    function graficar(){
      elMsg.textContent = '';
      elExpr.classList.remove('gf-err');
      elXmin.classList.remove('gf-err');
      elXmax.classList.remove('gf-err');

      var expr = elExpr.value.trim();
      var xmin = parseFloat(elXmin.value);
      var xmax = parseFloat(elXmax.value);

      if (!expr){ elMsg.textContent = 'Ingrese una expresión.'; return; }
      if (isNaN(xmin) || isNaN(xmax)){
        elXmin.classList.add('gf-err'); elXmax.classList.add('gf-err');
        elMsg.textContent = 'Intervalo no válido.'; return;
      }
      if (xmax <= xmin){
        elXmin.classList.add('gf-err'); elXmax.classList.add('gf-err');
        elMsg.textContent = 'Debe ser xmin < xmax.'; return;
      }

      var compiled = compile(expr);
      if (!compiled){
        elExpr.classList.add('gf-err');
        elMsg.textContent = 'La función digitada es incorrecta.'; return;
      }

      if (fns.length >= MAX_FNS){
        elMsg.textContent = 'Máximo ' + MAX_FNS + ' funciones simultáneas.'; return;
      }

      fns.push({
        expr: expr, xmin: xmin, xmax: xmax,
        color: COLORS[fns.length % COLORS.length],
        compiled: compiled
      });

      updateFnList();
      draw();
    }

    /* ── borrar última ── */
    function borrarUltima(){
      if (fns.length > 0){ fns.pop(); updateFnList(); draw(); }
    }

    /* ── borrar todo ── */
    function borrarTodo(){
      fns = []; puntos = []; updateFnList(); draw();
    }

    /* ── agregar punto ── */
    function agregarPunto(){
      var raw = document.getElementById('gf-punto-'+wid).value.trim();
      /* aceptar (a,b) o (a;b) o a,b o a;b */
      raw = raw.replace(/[()]/g, '');
      var parts = raw.split(/[,;]/);
      if (parts.length !== 2){
        elMsg.textContent = 'Punto: usar (a,b) o (a;b).'; return;
      }
      var px = parseFloat(parts[0].trim().replace(',','.'));
      var py = parseFloat(parts[1].trim().replace(',','.'));
      if (isNaN(px) || isNaN(py)){
        elMsg.textContent = 'Coordenadas del punto no válidas.'; return;
      }
      puntos.push({x:px, y:py});
      elMsg.textContent = '';
      draw();
    }

    /* ── borrar último punto ── */
    function borrarPunto(){
      if (puntos.length > 0){ puntos.pop(); draw(); }
    }

    /* ── exportar gráfico ── */
    function exportar(fmt){
      var W = canvas.offsetWidth, H = canvas.offsetHeight;
      if (fmt === 'png'){
        var link = document.createElement('a');
        link.download = 'grafico.png';
        link.href = canvas.toDataURL('image/png');
        link.click();
      } else if (fmt === 'pdf'){
        /* usar print del navegador solo con el canvas */
        var dataURL = canvas.toDataURL('image/png');
        var win = window.open('','_blank');
        win.document.write(
          '<html><head><title>Gráfico</title>'
          +'<style>@page{margin:1cm}body{margin:0;display:flex;justify-content:center;align-items:center;height:100vh}'
          +'img{max-width:100%;max-height:100%}</style>'
          +'<script>window.onload=function(){window.print();window.close()}<\/script>'
          +'</head><body><img src="'+dataURL+'"></body></html>'
        );
        win.document.close();
      } else if (fmt === 'svg'){
        /* construir SVG a partir de los datos actuales */
        var svgLines = [];
        svgLines.push('<svg xmlns="http://www.w3.org/2000/svg" width="'+W+'" height="'+H+'">');
        svgLines.push('<rect width="'+W+'" height="'+H+'" fill="white"/>');
        var x0 = W/2 + panX, y0 = H/2 + panY;

        /* grilla */
        for (var gx = x0 % escX; gx < W; gx += escX)
          svgLines.push('<line x1="'+gx+'" y1="0" x2="'+gx+'" y2="'+H+'" stroke="rgba(220,220,220,.8)" stroke-width="1"/>');
        for (var gy = y0 % escY; gy < H; gy += escY)
          svgLines.push('<line x1="0" y1="'+gy+'" x2="'+W+'" y2="'+gy+'" stroke="rgba(220,220,220,.8)" stroke-width="1"/>');

        /* ejes */
        svgLines.push('<line x1="'+x0+'" y1="8" x2="'+x0+'" y2="'+(H-8)+'" stroke="rgba(187,187,187,.9)" stroke-width="1.5"/>');
        svgLines.push('<line x1="8" y1="'+y0+'" x2="'+(W-8)+'" y2="'+y0+'" stroke="rgba(187,187,187,.9)" stroke-width="1.5"/>');

        /* funciones */
        fns.forEach(function(fn){
          if (!fn.compiled) return;
          var pts = [];
          var NPTS = Math.max(400, Math.round((fn.xmax-fn.xmin)*escX*2));
          var dx = (fn.xmax-fn.xmin)/NPTS;
          var seg = []; /* segmentos de polilínea */
          var cur = [];
          for (var i=0;i<=NPTS;i++){
            var xv = fn.xmin + i*dx;
            var yv = evalFn(fn.compiled, xv);
            if (!isFinite(yv)||isNaN(yv)){ if(cur.length>1)seg.push(cur); cur=[]; continue; }
            var cx = x0+xv*escX, cy = y0-yv*escY;
            if(cur.length>0 && Math.abs(cy-(cur[cur.length-1][1]))>H*1.5){ if(cur.length>1)seg.push(cur); cur=[]; }
            cur.push([cx,cy]);
          }
          if(cur.length>1)seg.push(cur);
          seg.forEach(function(s){
            var d = 'M'+s.map(function(p){return p[0].toFixed(2)+','+p[1].toFixed(2);}).join('L');
            svgLines.push('<path d="'+d+'" stroke="'+fn.color+'" stroke-width="'+lineW+'" fill="none" stroke-linejoin="round"/>');
          });
        });

        /* puntos */
        puntos.forEach(function(p){
          var cx=(x0+p.x*escX).toFixed(2), cy=(y0-p.y*escY).toFixed(2);
          svgLines.push('<circle cx="'+cx+'" cy="'+cy+'" r="'+(lineW+2)+'" fill="black"/>');
        });

        svgLines.push('</svg>');
        var blob = new Blob([svgLines.join('\n')], {type:'image/svg+xml'});
        var link = document.createElement('a');
        link.download = 'grafico.svg';
        link.href = URL.createObjectURL(blob);
        link.click();
      }
    }

    /* ── escalas ── */
    slSx.addEventListener('input', function(){
      escX = parseInt(slSx.value, 10);
      slSxV.textContent = escX;
      draw();
    });
    slSy.addEventListener('input', function(){
      escY = parseInt(slSy.value, 10);
      slSyV.textContent = escY;
      draw();
    });

    /* ── grosor ── */
    var selGrosor = document.getElementById('gf-lw-' + wid);
    if (selGrosor) selGrosor.addEventListener('change', function(){
      lineW = parseInt(this.value, 10);
      draw();
    });

    /* ── eventos ── */
    btnPlot.addEventListener('click', graficar);
    btnDel.addEventListener('click',  borrarUltima);
    btnClr.addEventListener('click',  borrarTodo);
    btnHelp.addEventListener('click', function(){ helpPanel.classList.toggle('open'); });

    /* botones export */
    var btnPng = document.getElementById('gf-exp-png-'+wid);
    var btnPdf = document.getElementById('gf-exp-pdf-'+wid);
    var btnSvg = document.getElementById('gf-exp-svg-'+wid);
    if (btnPng) btnPng.addEventListener('click', function(){ exportar('png'); });
    if (btnPdf) btnPdf.addEventListener('click', function(){ exportar('pdf'); });
    if (btnSvg) btnSvg.addEventListener('click', function(){ exportar('svg'); });

    /* reset pan */
    var btnReset = document.getElementById('gf-reset-'+wid);
    if (btnReset) btnReset.addEventListener('click', resetPan);

    /* puntos */
    var btnAddPt = document.getElementById('gf-addpt-'+wid);
    var btnDelPt = document.getElementById('gf-delpt-'+wid);
    if (btnAddPt) btnAddPt.addEventListener('click', agregarPunto);
    if (btnDelPt) btnDelPt.addEventListener('click', borrarPunto);
    var elPuntoIn = document.getElementById('gf-punto-'+wid);
    if (elPuntoIn) elPuntoIn.addEventListener('keydown', function(e){ if(e.key==='Enter') agregarPunto(); });

    elExpr.addEventListener('keydown', function(e){ if(e.key === 'Enter') graficar(); });

    if (window.ResizeObserver){
      new ResizeObserver(draw).observe(canvas);
    }

    /* estado inicial: graficar la función de ejemplo */
    draw();
    setTimeout(graficar, 200); /* esperar a math.js */
  }

  /* ── arrancar cuando math.js esté listo ── */
  function initAll(){
    if (typeof math === 'undefined'){ setTimeout(initAll, 80); return; }
    document.querySelectorAll('[id^="gf-widget-"]').forEach(function(el){
      new GrafWidget(el.id.replace('gf-widget-',''));
    });
  }

  window.GF_init = initAll;
  if (document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }

}());
</script>

<script>
(function(){
  document.querySelectorAll('.tec-info-toggle').forEach(function(btn){
    btn.addEventListener('click', function(){
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var body = document.getElementById(btn.getAttribute('aria-controls'));
      if (body) body.hidden = expanded;
    });
  });
}());
</script>
