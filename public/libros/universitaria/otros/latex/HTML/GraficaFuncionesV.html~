<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Graficador de Funciones</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- math.js para evaluar expresiones -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjs/13.0.3/math.min.js"></script>

  <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  GRAFICADOR DE FUNCIONES — prefijo .gf-                     ║
    ║  Hasta 10 funciones simultáneas con colores distintos       ║
    ║  Evaluador: math.js (reemplaza JEP)                         ║
    ╚══════════════════════════════════════════════════════════════╝
  -->
  <style>
    .gf-widget *, .gf-widget *::before, .gf-widget *::after {
      box-sizing: border-box; margin: 0; padding: 0;
    }

    .gf-widget {
      --gf-bg:      #1a3a52;
      --gf-darker:  #0f2233;
      --gf-mid:     #1e4560;
      --gf-lt:      #2a5a7a;
      --gf-teal:    #b0ffff;
      --gf-gold:    #c8922a;
      --gf-gold-lt: #e8b84b;
      --gf-accent:  #fdb851;   /* naranja-amarillo del botón original */
      --gf-error:   #ff6b6b;
      --gf-ink:     #0d1117;
      --gf-axis:    rgba(187,187,187,.7);
      --gf-grid:    rgba(220,220,220,.18);

      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      color: #fff;
      background: var(--gf-bg);
      border-radius: 8px;
      box-shadow: 0 6px 40px rgba(0,0,0,.32);
      overflow: hidden;
      width: 100%;
      max-width: 720px;
      margin: 0 auto;
      border: 2px solid var(--gf-darker);
    }

    /* ── header ── */
    .gf-header {
      background: var(--gf-darker);
      padding: .65rem 1.2rem;
      border-bottom: 1px solid var(--gf-lt);
      display: flex; align-items: baseline; gap: .75rem;
    }
    .gf-header h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.05rem; font-weight: 400; color: var(--gf-teal);
    }
    .gf-header span {
      font-family: 'DM Mono', monospace; font-size: .58rem;
      letter-spacing: .12em; text-transform: uppercase; color: var(--gf-gold-lt);
    }

    /* ── canvas ── */
    .gf-canvas-wrap {
      position: relative; width: 100%; aspect-ratio: 16/9;
      background: #fff; cursor: crosshair;
    }
    .gf-canvas { display: block; width: 100%; height: 100%; }

    /* coordenadas flotantes */
    .gf-coords {
      position: absolute; top: 6px; right: 8px;
      font-family: 'DM Mono', monospace; font-size: .7rem;
      color: #1a3a52; background: rgba(255,255,255,.82);
      padding: .18rem .5rem; border-radius: 3px;
      pointer-events: none; opacity: 0;
      transition: opacity .15s;
    }
    .gf-canvas-wrap:hover .gf-coords { opacity: 1; }

    /* ── panel de control ── */
    .gf-panel {
      background: var(--gf-bg);
      padding: .75rem 1.1rem;
      border-top: 1px solid var(--gf-lt);
      display: flex; flex-direction: column; gap: .6rem;
    }

    /* fila de entrada */
    .gf-input-row {
      display: grid;
      grid-template-columns: 1fr auto auto auto auto;
      gap: .45rem; align-items: center;
    }
    @media (max-width: 520px) {
      .gf-input-row { grid-template-columns: 1fr 1fr; }
      .gf-input-row .gf-expr { grid-column: 1 / -1; }
    }

    .gf-expr {
      width: 100%; padding: .38rem .6rem;
      font-family: 'DM Mono', monospace; font-size: .88rem;
      color: var(--gf-ink); background: #fff;
      border: 2px solid transparent; border-radius: 3px; outline: none;
      transition: border-color .15s;
    }
    .gf-expr:focus   { border-color: var(--gf-accent); }
    .gf-expr.gf-err  { border-color: var(--gf-error); color: #8a0000; }

    .gf-range-lbl {
      font-family: 'DM Mono', monospace; font-size: .68rem;
      color: rgba(176,255,255,.55); white-space: nowrap;
    }

    .gf-range-in {
      width: 62px; padding: .38rem .45rem;
      font-family: 'DM Mono', monospace; font-size: .82rem;
      color: var(--gf-ink); background: #fff;
      border: 2px solid transparent; border-radius: 3px; outline: none;
      text-align: center; transition: border-color .15s;
    }
    .gf-range-in:focus { border-color: var(--gf-accent); }
    .gf-range-in.gf-err { border-color: var(--gf-error); }

    /* botones */
    .gf-btn-row { display: flex; gap: .4rem; flex-wrap: wrap; align-items: center; }

    .gf-btn {
      padding: .38rem .9rem;
      font-family: 'DM Mono', monospace; font-size: .78rem; font-weight: 700;
      color: #002800; background: var(--gf-accent);
      border: none; border-radius: 3px; cursor: pointer;
      transition: background .14s, transform .08s;
    }
    .gf-btn:hover  { background: #fec96a; }
    .gf-btn:active { transform: scale(.96); }
    .gf-btn.del    { background: #d43030; color: #fff; }
    .gf-btn.del:hover { background: #e85050; }
    .gf-btn.help   { background: var(--gf-lt); color: var(--gf-teal); border: 1px solid #3a7aaa; }
    .gf-btn.help:hover { background: #3a7aaa; }
    .gf-btn.clr    { background: #2a3a4a; color: var(--gf-teal); border: 1px solid #3a5a7a; }
    .gf-btn.clr:hover  { background: #3a5a7a; }

    /* escalas */
    .gf-scale-row { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; }
    .gf-scale-field { display: flex; align-items: center; gap: .45rem; }
    .gf-scale-lbl { font-family: 'DM Mono', monospace; font-size: .62rem; color: rgba(176,255,255,.5); white-space: nowrap; }
    .gf-slider    { flex: 1; accent-color: var(--gf-accent); }
    .gf-scale-val { font-family: 'DM Mono', monospace; font-size: .7rem; color: var(--gf-gold-lt); min-width: 1.8rem; text-align: right; }

    /* lista de funciones graficadas */
    .gf-fn-list { display: flex; flex-direction: column; gap: .25rem; }
    .gf-fn-item {
      display: flex; align-items: center; gap: .5rem;
      font-family: 'DM Mono', monospace; font-size: .72rem;
    }
    .gf-fn-dot {
      width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
    }
    .gf-fn-expr { color: rgba(176,255,255,.8); }

    /* mensaje error */
    .gf-msg {
      font-family: 'DM Mono', monospace; font-size: .68rem;
      color: var(--gf-error); min-height: .85rem; letter-spacing: .04em;
    }

    /* ── panel ayuda ── */
    .gf-help-panel {
      display: none;
      background: var(--gf-darker); border-top: 1px solid var(--gf-lt);
      padding: .7rem 1.1rem; max-height: 220px; overflow-y: auto;
    }
    .gf-help-panel.open { display: block; }
    .gf-help-panel h3 {
      font-family: 'DM Mono', monospace; font-size: .65rem;
      letter-spacing: .12em; text-transform: uppercase;
      color: var(--gf-gold-lt); margin-bottom: .4rem;
    }
    .gf-help-panel table { width: 100%; border-collapse: collapse; font-family: 'DM Mono', monospace; font-size: .68rem; }
    .gf-help-panel td { padding: .1rem .5rem; vertical-align: top; color: rgba(176,255,255,.75); }
    .gf-help-panel td:first-child { color: var(--gf-teal); width: 30%; }

    /* ── footer ── */
    .gf-footer {
      padding: .38rem 1.2rem; border-top: 1px solid var(--gf-darker);
      font-family: 'DM Mono', monospace; font-size: .58rem;
      letter-spacing: .1em; color: rgba(176,255,255,.25); text-align: right;
    }

    /* botones export */
    .gf-btn.exp-png { background: #2e6e4a; color: #fff; }
    .gf-btn.exp-png:hover { background: #3a8a5c; }
    .gf-btn.exp-pdf { background: #6e2e2e; color: #fff; }
    .gf-btn.exp-pdf:hover { background: #8a3a3a; }
    .gf-btn.exp-svg { background: #3a3a8a; color: #fff; }
    .gf-btn.exp-svg:hover { background: #5050aa; }
    .gf-btn.reset-pan { background: #4a4a2e; color: #e8d87a; border: 1px solid #7a7a3a; }
    .gf-btn.reset-pan:hover { background: #6a6a3a; }
    .gf-btn.addpt { background: #2a5a4a; color: #b0ffdd; border: 1px solid #3a8a6a; }
    .gf-btn.addpt:hover { background: #3a7a5a; }
    .gf-btn.delpt:hover { background: #7a3a5a; }

    .gf-select {
      padding: .32rem .5rem;
      font-family: 'DM Mono', monospace; font-size: .78rem;
      color: var(--gf-ink); background: #fff;
      border: 2px solid transparent; border-radius: 3px; outline: none;
      cursor: pointer; transition: border-color .15s;
    }
    .gf-select:focus { border-color: var(--gf-accent); }

    .gf-row-label {
      font-family: 'DM Mono', monospace; font-size: .65rem;
      color: rgba(176,255,255,.45); white-space: nowrap; letter-spacing: .06em;
    }
    .gf-section-sep {
      border: none; border-top: 1px solid rgba(176,255,255,.12); margin: .1rem 0;
    }

    @keyframes gf-pop { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
    .gf-widget { animation: gf-pop .32s ease both; }
  </style>
<!-- ── TEC PAGE STYLES ── -->
<style>
:root {
  --tec-bg:      #f0ede8;
  --tec-ink:     #0d1117;
  --tec-accent:  #1a4f8a;
  --tec-gold:    #c8922a;
  --tec-gold-lt: #e8b84b;
  --tec-rule:    #d4cfc9;
  --tec-muted:   #7a7269;
  --tec-info-bg: #eef3fb;
}
@media (prefers-color-scheme: dark) {
  :root {
    --tec-bg:      #0d1117;
    --tec-ink:     #e4dfd8;
    --tec-accent:  #4a9ade;
    --tec-gold-lt: #e8b84b;
    --tec-rule:    #1e2d3d;
    --tec-muted:   #8a8279;
    --tec-info-bg: #0f2035;
  }
}
html { font-size: 16px; }
body {
  margin: 0;
  background: var(--tec-bg);
  color: var(--tec-ink);
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  line-height: 1.6;
  min-height: 100vh;
  padding: 1.5rem 0 2rem;
}
.tec-page {
  max-width: 880px;
  margin: 0 auto;
  padding: 0 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.tec-header { border-bottom: 2px solid var(--tec-gold); padding-bottom: .75rem; }
.tec-eyebrow {
  font-family: 'DM Mono', monospace;
  font-size: .7rem; letter-spacing: .2em; text-transform: uppercase;
  color: var(--tec-muted); margin: 0 0 .2rem;
}
.tec-course-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.5rem; font-weight: 400; margin: 0; line-height: 1.2;
  color: var(--tec-ink);
}
.tec-course-link {
  color: var(--tec-accent); text-decoration: none;
  border-bottom: 1px solid transparent; transition: border-color .2s;
}
.tec-course-link:hover { border-bottom-color: var(--tec-accent); }
.tec-info {
  background: var(--tec-info-bg); border: 1px solid var(--tec-rule);
  border-radius: 6px; overflow: hidden;
}
.tec-info-toggle {
  width: 100%; padding: .75rem 1.1rem; background: none; border: none;
  cursor: pointer; display: flex; align-items: center; gap: .55rem;
  font-family: 'DM Mono', monospace; font-size: .78rem; letter-spacing: .1em;
  text-transform: uppercase; color: var(--tec-accent); text-align: left;
  transition: background .2s;
}
.tec-info-toggle:hover { background: rgba(26,79,138,.07); }
.tec-info-icon { display: inline-block; transition: transform .22s; font-size: .6rem; }
.tec-info-toggle[aria-expanded="true"] .tec-info-icon { transform: rotate(90deg); }
.tec-info-body {
  padding: 1rem 1.1rem 1.2rem; border-top: 1px solid var(--tec-rule);
  display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.25rem;
}
@media (max-width: 640px) { .tec-info-body { grid-template-columns: 1fr; } }
[hidden] { display: none !important; }

.tec-info-body h3 {
  font-family: 'DM Mono', monospace; font-size: .66rem; letter-spacing: .14em;
  text-transform: uppercase; color: var(--tec-gold); margin: 0 0 .45rem;
}
.tec-info-body p, .tec-info-body li { font-size: .88rem; color: var(--tec-ink); line-height: 1.65; }
.tec-info-body ol, .tec-info-body ul { padding-left: 1.1rem; margin: 0; }
.tec-info-body li { margin-bottom: .3rem; }
.home-footer {
  border-top: 1px solid var(--tec-rule); padding: .85rem 0;
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: .5rem;
  font-family: 'DM Mono', monospace; font-size: .72rem; letter-spacing: .08em;
}
.footer-brand { color: var(--tec-muted); text-transform: uppercase; }
.footer-link { color: var(--tec-accent); text-decoration: none; transition: color .2s; }
.footer-link:hover { color: var(--tec-gold-lt); }
</style>

<style id="tec-mobile">
/* ── responsive mobile ── */
@media (max-width: 720px) {
  body { padding: 0.75rem 0 1.5rem; }
  .tec-page { padding: 0 0.75rem; gap: 1rem; }
  .tec-course-title { font-size: 1rem; }
}
/* ── scroll en panel de instrucciones ── */
.tec-info-body {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
@media (max-width: 640px) {
  .tec-info-body { overflow-x: hidden; overflow-y: auto; max-height: 60vh; }
}
/* ── scroll en el widget / script area ── */
.tec-page > div[class*="-widget"],
.tec-page > div[class*="-card"],
.tec-page > div[class$="-wrap"],
.tec-page > .widget-outer {
  overflow: auto;
  -webkit-overflow-scrolling: touch;
  max-width: 100%;
}
/* contenedor genérico del widget cuando no tiene clase scrollable */
.tec-widget-scroll {
  overflow: auto;
  -webkit-overflow-scrolling: touch;
  max-width: 100%;
}
</style>
</head>
<body>
<div class="tec-page" role="main">
<header class="tec-header" role="banner">
  <p class="tec-eyebrow">Instituto Tecnológico de Costa Rica</p>
  <h1 class="tec-course-title">
    <a class="tec-course-link" href="https://tecdigital.tec.ac.cr/servicios/revistamatematica/libros/" target="_blank">
      Edición de Textos Científicos La<span style="position:relative;top:-.12em;font-size:.82em;">T</span>e<span style="position:relative;top:.1em;font-size:.82em;">X</span> (2026)
    </a>
  </h1>
</header>

<section class="tec-info" aria-label="Información de la herramienta">
  <button class="tec-info-toggle" aria-expanded="false" aria-controls="info-graficafuncionesv">
    <span class="tec-info-icon">▶</span>
    Instrucciones y experimentos
  </button>
  <div class="tec-info-body" id="info-graficafuncionesv" hidden>
    <div><h3>Propósito</h3><p>Graficador de funciones matemáticas generales para visualizar densidades de probabilidad, funciones de distribución acumulada o cualquier función relevante en el estudio de probabilidad.</p></div>
    <div><h3>Cómo usar</h3><ol>
        <li>Ingrese la expresión f(x) en la sintaxis matemática indicada.</li>
        <li>Defina el rango del eje x (mínimo y máximo).</li>
        <li>Ajuste el rango del eje y si es necesario.</li>
        <li>Presione Graficar para visualizar.</li>
    </ol></div>
    <div><h3>Experimentos sugeridos</h3><ul>
        <li>Grafica la densidad normal: exp(−x²/2)/sqrt(2*pi) en [−4,4].</li>
        <li>Grafica la CDF exponencial: 1−exp(−x) en [0,6].</li>
        <li>Compara f(x)=x² con g(x)=sqrt(x) en [0,2].</li>
    </ul></div>
  </div>
</section>

<div class="gf-widget" id="gf-widget-1">

  <div class="gf-header">
    <h2>Graficador de Funciones</h2>
    <span>hasta 10 funciones · math.js</span>
  </div>

  <!-- canvas -->
  <div class="gf-canvas-wrap" id="gf-wrap-1">
    <canvas class="gf-canvas" id="gf-cv-1"></canvas>
    <div class="gf-coords" id="gf-coords-1"></div>
  </div>

  <!-- panel de control -->
  <div class="gf-panel">

    <!-- fila expresión + intervalo -->
    <div class="gf-input-row">
      <input class="gf-expr" id="gf-expr-1" type="text"
             value="abs(x*sin(x))-4" autocomplete="off"
             placeholder="f(x) — ej: sin(x), x^2-3, ...">
      <span class="gf-range-lbl">x ∈ [</span>
      <input class="gf-range-in" id="gf-xmin-1" type="text" value="-15" inputmode="decimal" autocomplete="off">
      <span class="gf-range-lbl">,</span>
      <input class="gf-range-in" id="gf-xmax-1" type="text" value="15" inputmode="decimal" autocomplete="off">
      <span class="gf-range-lbl">]</span>
    </div>

    <!-- botones principales -->
    <div class="gf-btn-row">
      <button class="gf-btn" id="gf-plot-1">▶ Graficar</button>
      <button class="gf-btn del" id="gf-del-1">✕ Borrar última</button>
      <button class="gf-btn clr" id="gf-clr-1">⊘ Borrar todo</button>
      <button class="gf-btn help" id="gf-help-1">? Ayuda</button>
    </div>

    <hr class="gf-section-sep">

    <!-- fila grosor + pan reset -->
    <div class="gf-btn-row" style="align-items:center;">
      <span class="gf-row-label">Grosor:</span>
      <select class="gf-select" id="gf-lw-1">
        <option value="1">1 px</option>
        <option value="2" selected>2 px</option>
        <option value="3">3 px</option>
      </select>
      <button class="gf-btn reset-pan" id="gf-reset-1" title="Restablecer posición del gráfico">⌖ Centrar</button>
    </div>

    <hr class="gf-section-sep">

    <!-- exportar -->
    <div class="gf-btn-row" style="align-items:center;">
      <span class="gf-row-label">Exportar:</span>
      <button class="gf-btn exp-png" id="gf-exp-png-1">⬇ PNG</button>
      <button class="gf-btn exp-svg" id="gf-exp-svg-1">⬇ SVG</button>
      <button class="gf-btn exp-pdf" id="gf-exp-pdf-1">⬇ PDF</button>
    </div>

    <hr class="gf-section-sep">

    <!-- puntos -->
    <div class="gf-btn-row" style="align-items:center; flex-wrap:wrap;">
      <span class="gf-row-label">Punto:</span>
      <input class="gf-expr" id="gf-punto-1" type="text"
             style="max-width:130px;" placeholder="(a,b) o (a;b)"
             autocomplete="off">
      <button class="gf-btn addpt" id="gf-addpt-1">● Agregar</button>
      <button class="gf-btn delpt" id="gf-delpt-1">✕ Quitar</button>
    </div>

    <!-- escalas -->
    <div class="gf-scale-row">
      <div class="gf-scale-field">
        <span class="gf-scale-lbl">Escala X</span>
        <input class="gf-slider" id="gf-sx-1" type="range" min="5" max="80" value="30" step="1">
        <span class="gf-scale-val" id="gf-sxv-1">30</span>
      </div>
      <div class="gf-scale-field">
        <span class="gf-scale-lbl">Escala Y</span>
        <input class="gf-slider" id="gf-sy-1" type="range" min="5" max="80" value="30" step="1">
        <span class="gf-scale-val" id="gf-syv-1">30</span>
      </div>
    </div>

    <!-- lista de funciones -->
    <div class="gf-fn-list" id="gf-fnlist-1"></div>

    <!-- mensaje -->
    <div class="gf-msg" id="gf-msg-1"></div>

  </div>

  <!-- ayuda -->
  <div class="gf-help-panel" id="gf-help-panel-1">
    <h3>Comandos disponibles</h3>
    <table>
      <tr><td>+ − * / ^ %</td><td>aritmética básica; potencia: x^2</td></tr>
      <tr><td>sin cos tan</td><td>trigonométricas: sin(x^2)</td></tr>
      <tr><td>asin acos atan</td><td>inversas trig: atan(x-3)</td></tr>
      <tr><td>sinh cosh tanh</td><td>hiperbólicas: cosh(1/x)</td></tr>
      <tr><td>asinh acosh atanh</td><td>inversas hiperbólicas</td></tr>
      <tr><td>log(x) / log(x,b)</td><td>log natural / base b: log(100,10)=2</td></tr>
      <tr><td>log10(x)</td><td>logaritmo base 10</td></tr>
      <tr><td>sqrt(x) / abs(x)</td><td>raíz cuadrada / valor absoluto</td></tr>
      <tr><td>exp(x)</td><td>e^x</td></tr>
      <tr><td>floor ceil round</td><td>redondeo</td></tr>
      <tr><td>pi, e</td><td>constantes: pi, e</td></tr>
      <tr><td>random()</td><td>número aleatorio [0,1)</td></tr>
    </table>
    <h3 style="margin-top:.5rem;">Operadores lógicos (retornan 0 ó 1)</h3>
    <table>
      <tr><td>== != &gt; &lt; &gt;= &lt;=</td><td>comparación: x&gt;2</td></tr>
      <tr><td>! and or</td><td>lógicos: and(x&gt;0, x&lt;5)</td></tr>
    </table>
    <h3 style="margin-top:.5rem;">Nota</h3>
    <table>
      <tr><td colspan="2">Escribir -x^2 se interpreta como -(x^2). Para elevar -x al cuadrado: (-x)^2.</td></tr>
      <tr><td colspan="2">Click o arrastre en la gráfica para ver coordenadas.</td></tr>
    </table>
  </div>

